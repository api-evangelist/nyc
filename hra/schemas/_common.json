{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/nyc/main/hra/schemas/_common.json",
  "title": "HRA — Shared Definitions",
  "description": "Reusable JSON Schema definitions shared across NYC Human Resources Administration / Department of Social Services (HRA/DSS) object schemas. Reconciles fields common to the HRA Open Data datasets (data.cityofnewyork.us), nyc.gov/site/hra, the ACCESS NYC eligibility screener (access.nyc.gov, open-source Drools rules engine), and the ACCESS HRA application portal (a069-access.nyc.gov). Includes the NYC geography spine and HRA's benefit-program vocabulary (SNAP, Cash Assistance, Medicaid).",
  "$defs": {
    "Borough": {
      "type": "string",
      "enum": ["Manhattan", "Bronx", "Brooklyn", "Queens", "Staten Island"]
    },
    "Coordinates": {
      "type": "object",
      "description": "WGS84 point (Open Data Latitude / Longitude).",
      "properties": {
        "latitude": { "type": "number", "minimum": -90, "maximum": 90 },
        "longitude": { "type": "number", "minimum": -180, "maximum": 180 }
      },
      "required": ["latitude", "longitude"],
      "additionalProperties": false
    },
    "Geography": {
      "type": "object",
      "description": "The NYC geography spine shared across HRA datasets — the join keys back to the rest of city government.",
      "properties": {
        "borough": { "$ref": "#/$defs/Borough" },
        "communityBoard": { "type": ["string", "integer", "null"], "description": "Community District / Board ('Community Board' / 'Community District (CD)')." },
        "councilDistrict": { "type": ["integer", "null"], "minimum": 1, "maximum": 51, "description": "NYC Council district ('Council District')." },
        "censusTract": { "type": ["string", "null"], "description": "Census tract ('Census Tract' / 'Census Tract (2020)')." },
        "nta": { "type": ["string", "null"], "description": "Neighborhood Tabulation Area name or code ('NTA' / 'Neighborhood Tabulation Area (NTA) (2020)')." },
        "bbl": { "type": ["string", "null"], "description": "Borough-Block-Lot ('BBL')." },
        "bin": { "type": ["string", "null"], "description": "Building Identification Number ('BIN')." }
      },
      "additionalProperties": false
    },
    "BenefitProgram": {
      "type": "string",
      "description": "A public-benefit program administered or screened by HRA/DSS.",
      "enum": [
        "SNAP",
        "Cash Assistance",
        "Medicaid",
        "HEAP",
        "Fair Fares",
        "HASA",
        "Emergency Assistance",
        "Child Support",
        "Adult Protective Services",
        "IDNYC",
        "Home Care",
        "Homebase",
        "Other"
      ]
    },
    "ProgramReference": {
      "type": "object",
      "description": "A reference to a benefit/program by its ACCESS NYC / NYC Benefits Platform codes.",
      "properties": {
        "programName": { "type": "string", "description": "Program name ('program_name' / 'plain_language_program_name')." },
        "program": { "$ref": "#/$defs/BenefitProgram" },
        "programCode": { "type": ["string", "null"], "description": "NYC Benefits Platform 'program_code'." },
        "programAcronym": { "type": ["string", "null"], "description": "'program_acronym'." }
      },
      "required": ["programName"],
      "additionalProperties": false
    },
    "Money": {
      "type": ["number", "null"],
      "description": "A US-dollar amount."
    }
  }
}
