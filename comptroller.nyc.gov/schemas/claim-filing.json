{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/nyc/main/comptroller.nyc.gov/schemas/claim-filing.json",
  "title": "ClaimFiling",
  "description": "NET-NEW WRITE object. A citizen's filing of a claim against the City of New York — the transactional workflow behind the Comptroller's eClaim system (comptroller.nyc.gov/services/for-the-public/claims/file-a-claim). No public API exists for this today; this is the one net-new write surface for the domain. The settled record is later reported as `claim.json`.",
  "type": "object",
  "x-source": {
    "workflow": "https://comptroller.nyc.gov/services/for-the-public/claims/file-a-claim/",
    "system": "NYC eClaim"
  },
  "properties": {
    "confirmationNumber": { "type": ["string", "null"], "description": "Server-assigned confirmation number (read-only, returned on submission)." },
    "status": {
      "type": ["string", "null"],
      "description": "Filing status (read-only).",
      "enum": ["received", "under_review", "acknowledged", "rejected", null]
    },
    "claimType": {
      "type": "string",
      "description": "Type of claim being filed.",
      "enum": ["Personal Injury", "Property Damage", "Motor Vehicle", "Wrongful Death", "Sidewalk", "Pothole", "Property Tax Refund", "Other"]
    },
    "claimant": {
      "type": "object",
      "description": "The person or entity filing the claim.",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": ["string", "null"], "format": "email" },
        "phone": { "type": ["string", "null"] },
        "address": { "$ref": "_common.json#/$defs/Location" },
        "representedByAttorney": { "type": ["boolean", "null"] }
      },
      "required": ["name"],
      "additionalProperties": false
    },
    "agencyInvolved": { "$ref": "_common.json#/$defs/AgencyReference" },
    "incidentDate": { "type": "string", "format": "date", "description": "Date the incident/occurrence took place." },
    "incidentLocation": { "$ref": "_common.json#/$defs/Location" },
    "description": { "type": "string", "description": "Narrative description of the claim." },
    "amountClaimed": { "$ref": "_common.json#/$defs/Money", "description": "Damages amount sought." },
    "supportingDocuments": {
      "type": "array",
      "description": "References to uploaded supporting documents (photos, reports, bills).",
      "items": {
        "type": "object",
        "properties": {
          "filename": { "type": "string" },
          "url": { "type": ["string", "null"], "format": "uri" },
          "contentType": { "type": ["string", "null"] }
        },
        "required": ["filename"],
        "additionalProperties": false
      }
    },
    "submittedAt": { "type": ["string", "null"], "format": "date-time", "description": "Submission timestamp (read-only)." }
  },
  "required": ["claimType", "claimant", "incidentDate", "description"],
  "additionalProperties": false
}
