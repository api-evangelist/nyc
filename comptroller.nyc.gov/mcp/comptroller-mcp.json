  "server": {
    "name": "io.nyc.comptroller",
    "title": "NYC Comptroller",
    "version": "0.1.0",
    "description": "Agent-native access to the New York City Office of the Comptroller \u2014 City spending and contracts (Checkbook NYC), published audits, claims against the City, and the five pension funds' holdings. Consolidates the existing XML-first Checkbook API and the Comptroller's Open Data behind one owned, resource-oriented surface; adds the net-new eClaim filing workflow.",
    "instructions": "Use find_spending / get_spending_transaction and find_contracts / get_contract to answer 'how much did the City pay vendor X?' or 'which contracts did agency Y register?' \u2014 these front the Checkbook NYC API in JSON. find_audits surfaces Bureau of Audit reports. find_claims reads reported claim dispositions; file_claim (net-new) files a NEW claim against the City via eClaim, requires an authenticated user, and mutates state \u2014 confirm all details with the user before submitting. find_pension_holdings covers NYCERS/TRS/BERS/Police/Fire investments."
  },
  "capabilities": {
    "tools": {
      "listChanged": false
    }
  },
  "tools": [
    {
      "name": "find_spending",
      "title": "Find Spending Transactions",
      "description": "Search NYC spending (payment) transactions by fiscal year, agency, vendor, expense category, contract, or amount. Fronts the Checkbook NYC Spending domain in JSON.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "fiscalYear": {
            "type": "integer",
            "minimum": 1990,
            "maximum": 2100
          },
          "agency": {
            "type": "string"
          },
          "vendor": {
            "type": "string"
          },
          "expenseCategory": {
            "type": "string"
          },
          "contractId": {
            "type": "string"
          },
          "minAmount": {
            "type": "number"
          },
          "q": {
            "type": "string"
          },
          "page": {
            "type": "integer",
            "minimum": 1,
            "default": 1
          },
          "perPage": {
            "type": "integer",
            "minimum": 1,
            "maximum": 200,
            "default": 50
          }
        }
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "../schemas/spending-transaction.json"
            }
          }
        }
      },
      "annotations": {
        "readOnlyHint": true,
        "openWorldHint": true
      },
      "x-openapi-operation": "listSpending",
      "x-agent-skill": "search-city-data-and-records"
    },
    {
      "name": "get_spending_transaction",
      "title": "Get Spending Transaction",
      "description": "Fetch a single spending transaction by document id.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "documentId": {
            "type": "string"
          }
        },
        "required": [
          "documentId"
        ]
      },
      "outputSchema": {
        "$ref": "../schemas/spending-transaction.json"
      },
      "annotations": {
        "readOnlyHint": true,
