  "server": {
    "name": "io.nyc.sbs",
    "title": "NYC Small Business Services (SBS)",
    "version": "0.1.0",
    "description": "Agent-native access to the NYC Department of Small Business Services \u2014 SBS-certified M/WBE businesses, Business Improvement Districts, Workforce1 recruitment events and job listings, NYC Business Solutions / Workforce1 service centers, and business-incentive records from NYC Open Data, plus the net-new ability to apply for and track M/WBE certification, which today lives only in the MyCity Business portal.",
    "instructions": "Use find_certified_businesses / get_certified_business to locate SBS-certified vendors by borough, certification type, NAICS industry, or free text. find_business_improvement_districts / get_business_improvement_district cover BIDs and their trends. find_workforce_events and find_job_listings surface Workforce1 hiring events and open positions; find_service_locations returns Business Solutions Centers and Workforce1 Career Centers. find_incentives answers questions about SBS-administered benefits (energy cost savings, ICAP abatement, acceleration). apply_for_mwbe_certification (net-new) submits an M/WBE / EBE / LBE certification application; it requires an authenticated business owner and mutates state \u2014 confirm the legal business name, ownership, industry, and certification requested with the user before submitting. Approved applicants later appear in the public certified business list."
  },
  "capabilities": {
    "tools": {
      "listChanged": false
    }
  },
  "tools": [
    {
      "name": "find_certified_businesses",
      "title": "Find Certified Businesses",
      "description": "Search SBS-certified M/WBE, EBE, LBE, and EO50 businesses by borough, certification type, NAICS industry, ethnicity, and/or free text.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "borough": {
            "type": "string",
            "enum": [
              "Manhattan",
              "Bronx",
              "Brooklyn",
              "Queens",
              "Staten Island"
            ]
          },
          "certification": {
            "type": "string",
            "enum": [
              "MBE",
              "WBE",
              "MWBE",
              "EBE",
              "LBE",
              "DBE",
              "EO50"
            ]
          },
          "naicsCode": {
            "type": "string"
          },
          "ethnicity": {
            "type": "string"
          },
          "q": {
            "type": "string"
          },
          "page": {
            "type": "integer",
            "minimum": 1,
            "default": 1
          },
          "perPage": {
            "type": "integer",
            "minimum": 1,
            "maximum": 200,
            "default": 50
          }
        }
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "../schemas/certified-business.json"
            }
          }
        }
      },
      "annotations": {
        "readOnlyHint": true,
        "openWorldHint": true
      },
      "x-openapi-operation": "listCertifiedBusinesses",
      "x-agent-skill": "search-city-data-and-records"
    },
