{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/nyc/main/edc/schemas/development-project.json",
  "title": "DevelopmentProject",
  "description": "An EDC economic-development / capital project — waterfront, industrial, neighborhood, life-sciences, and infrastructure investments that EDC leads or manages. MODELED ENTITY: EDC lists projects on edc.nyc but publishes NO Open Data dataset and NO API for its project portfolio. Schema reverse-engineered from the edc.nyc 'Projects' presentation; keyed on a project identifier and the NYC geography spine.",
  "type": "object",
  "x-source": {
    "site": "https://edc.nyc/projects",
    "opendata": null,
    "opendata_gap": true
  },
  "properties": {
    "projectId": { "type": ["string", "null"], "description": "EDC project identifier / slug." },
    "name": { "type": "string", "description": "Project name." },
    "summary": { "type": ["string", "null"], "description": "Short description of the project." },
    "category": { "type": ["string", "null"], "description": "Project category (e.g. Waterfront, Industrial, Life Sciences, Neighborhood, Infrastructure)." },
    "status": { "$ref": "_common.json#/$defs/ProjectStatus" },
    "program": { "$ref": "_common.json#/$defs/IncentiveProgram" },
    "neighborhood": { "type": ["string", "null"], "description": "Primary neighborhood." },
    "investment": { "type": ["number", "null"], "description": "Announced public/private investment (USD), if disclosed." },
    "jobsProjected": { "type": ["integer", "null"], "description": "Projected jobs created/retained, if disclosed." },
    "startYear": { "type": ["integer", "null"] },
    "completionYear": { "type": ["integer", "null"] },
    "url": { "type": ["string", "null"], "format": "uri", "description": "Project page on edc.nyc." },
    "address": { "$ref": "_common.json#/$defs/Address" },
    "geography": { "$ref": "_common.json#/$defs/Geography" },
    "coordinates": { "$ref": "_common.json#/$defs/Coordinates" }
  },
  "required": ["name"],
  "additionalProperties": false
}
