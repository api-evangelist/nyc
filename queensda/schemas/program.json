{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/nyc/main/queensda/schemas/program.json",
  "title": "Program",
  "description": "A Queens DA program, initiative, or diversion offering — the community-facing side of the office (e.g. A Bridge to Change, Brave Justice, Blazing the Trail, Community Partnerships, Youth Development & Crime Prevention, Community Violence Prevention). Today each is a hand-built WordPress page with no common shape; this schema is the structured resource for the office's programmatic work.",
  "type": "object",
  "x-source": {
    "wp_rest": "https://queensda.org/wp-json/wp/v2/pages",
    "site": "https://queensda.org/special-initiatives/",
    "opendata": null,
    "opendata_gap": true
  },
  "properties": {
    "publication": { "$ref": "_common.json#/$defs/Publication" },
    "name": { "type": "string", "description": "Program/initiative name." },
    "category": {
      "type": ["string", "null"],
      "enum": ["diversion", "youth", "community-partnership", "violence-prevention", "reentry", "conviction-integrity", "special-initiative", "other", null],
      "description": "Kind of program."
    },
    "description": { "type": ["string", "null"], "description": "What the program does." },
    "eligibility": { "type": ["string", "null"], "description": "Who the program serves / eligibility criteria." },
    "status": { "type": ["string", "null"], "enum": ["active", "archived", "rfp-open", null], "description": "Some pages are archived RFPs." },
    "contact": { "$ref": "_common.json#/$defs/ContactPoint" },
    "geography": { "$ref": "_common.json#/$defs/Geography" }
  },
  "required": ["name"],
  "additionalProperties": false
}
