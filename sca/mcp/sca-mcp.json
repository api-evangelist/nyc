      "title": "Find Capital Projects",
      "description": "Search SCA school-construction capital projects by borough, geographic (school) district, project type, status, and/or free text.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "borough": {
            "type": "string",
            "enum": [
              "Manhattan",
              "Bronx",
              "Brooklyn",
              "Queens",
              "Staten Island"
            ]
          },
          "geographicDistrict": {
            "type": "string"
          },
