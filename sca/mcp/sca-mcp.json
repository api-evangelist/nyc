  "server": {
    "name": "io.nyc.sca",
    "title": "NYC School Construction Authority (SCA)",
    "version": "0.1.0",
    "description": "Agent-native access to the NYC School Construction Authority \u2014 school-construction capital projects, upcoming CIP/CAP contracts, RFP solicitations, the prequalified/disqualified vendor roster, enrollment and capacity, and construction inspections from NYC Open Data, plus the net-new ability to apply to become a prequalified vendor \u2014 a workflow that today lives only in PDF forms and the bidset SharePoint portal.",
    "instructions": "Use find_capital_projects / get_capital_project to locate school-construction projects by borough, geographic (school) district, type, or status and drill into schedules, budgets, and capacity. find_upcoming_contracts and find_solicitations cover the forward procurement pipeline (CIP/CAP awards and current/anticipated RFPs) vendors watch. find_vendors searches the prequalified vendor roster (filter by trade code or M/WBE/local certifications, or disqualified=true for barred firms). find_enrollment_capacity returns the demand signal behind the capital plan; find_inspections covers field inspection requests and observations. apply_for_prequalification (net-new) submits a vendor prequalification application; it requires an authenticated firm and mutates state \u2014 confirm the firm name, request type, and trade code with the user before submitting. list_my_prequalifications tracks an authenticated firm's own applications."
  },
  "capabilities": {
    "tools": {
      "listChanged": false
    }
  },
  "tools": [
    {
