{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/nyc/main/sca/schemas/solicitation.json",
  "title": "Solicitation",
  "description": "An SCA Request for Proposals (RFP) / services solicitation — the professional-services procurement notices vendors respond to. Canonical schema reconciling 'Current RFP' (bzjf-rmtp, 7 columns) and 'Anticipated RFP' (p8e4-uwuv, 5 columns). The bid documents themselves live in the login-walled bidset SharePoint portal; this schema is the open notice metadata.",
  "type": "object",
  "x-source": {
    "opendata_current": "https://data.cityofnewyork.us/d/bzjf-rmtp",
    "opendata_anticipated": "https://data.cityofnewyork.us/d/p8e4-uwuv",
    "bidset_portal": "https://bidset.nycsca.org/",
    "site": "https://www.nycsca.org/Business/Business-Opportunities"
  },
  "properties": {
    "stage": {
      "type": ["string", "null"],
      "enum": ["Anticipated", "Current", null],
      "description": "Whether this is an anticipated (upcoming) or currently open RFP."
    },
    "solicitationNumber": { "type": ["string", "null"], "description": "'Solicitation Number' (Current RFP)." },
    "services": { "type": ["string", "null"], "description": "'Services' — the service being procured." },
    "department": { "type": ["string", "null"], "description": "'Department' issuing the solicitation." },
    "dueDate": { "type": ["string", "null"], "format": "date", "description": "'Due Date' (Current RFP)." },
    "numberOfContracts": { "type": ["integer", "null"], "description": "'Number of Contract(s)' / 'Anticipated number of Contracts'." },
    "notToExceedAwardPerContract": { "$ref": "_common.json#/$defs/MoneyUSD", "description": "'Not-To-Exceed Award Amount per Contract' (Current RFP)." },
    "estimatedCostPerContract": { "$ref": "_common.json#/$defs/MoneyUSD", "description": "'Estimated Cost of Service per Contract' (Anticipated RFP)." },
    "dataAsOf": { "type": ["string", "null"], "format": "date", "description": "'Data as of Date'." }
  },
  "additionalProperties": false
}
