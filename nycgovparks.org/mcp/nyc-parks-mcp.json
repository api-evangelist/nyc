{
  "$schema": "https://raw.githubusercontent.com/api-evangelist/nyc/main/nycgovparks.org/mcp/_mcp-artifact.schema.json",
  "x-artifact": {
    "kind": "mcp-server-definition",
    "designFirst": true,
    "deployed": false,
    "note": "Design-first artifact only. This describes the MCP server's tool surface \u2014 it is NOT a running server. Tool input/output schemas $ref the same object schemas used by the OpenAPI; each tool maps to an OpenAPI operationId so the REST contract and the agent contract stay in lockstep.",
    "openapi": "../openapi/nyc-parks.yaml",
    "schemas": "../schemas/"
  },
  "server": {
    "name": "io.nyc.parks",
    "title": "NYC Parks",
    "version": "0.1.0",
    "description": "Agent-native access to NYC Department of Parks & Recreation resources \u2014 parks, facilities, events, monuments, trees, capital projects, and permit applications. Unifies data today split between nycgovparks.org HTML and NYC Open Data, plus the net-new permit-application workflow.",
    "instructions": "Use the find_* tools to search resources and the get_* tools to fetch one by id. Parks are the root entity; a park's gisPropNum joins it to its facilities, events, monuments, and capital projects. Read tools are open/anonymous. Permit tools (submit/get/list/update_permit_application) require an authenticated applicant token and mutate state \u2014 confirm intent with the user before submitting."
  },
  "capabilities": {
    "tools": {
      "listChanged": false
    }
  },
  "tools": [
    {
      "name": "find_parks",
      "title": "Find Parks",
      "description": "Search NYC park properties by borough and/or free text. Returns a page of parks.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "borough": {
            "type": "string",
            "enum": [
              "Bronx",
              "Brooklyn",
              "Manhattan",
              "Queens",
              "Staten Island"
            ]
          },
          "q": {
            "type": "string",
            "description": "Free-text search over park name/location."
          },
          "page": {
            "type": "integer",
            "minimum": 1,
            "default": 1
          },
          "perPage": {
            "type": "integer",
            "minimum": 1,
            "maximum": 200,
            "default": 50
          }
        }
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "../schemas/park.json"
            }
          }
        }
      },
      "annotations": {
        "readOnlyHint": true,
        "openWorldHint": true
      },
      "x-openapi-operation": "listParks",
      "x-agent-skill": "look-up-a-property-or-place"
    },
    {
      "name": "get_park",
      "title": "Get Park",
      "description": "Fetch a single park by its GIS property number (gisPropNum).",
