{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/nyc/main/nycgovparks.org/schemas/facility.json",
  "title": "Facility",
  "description": "A recreational facility within a park (court, field, pool, playground, dog run, restroom, etc.). Canonical schema reconciling the ~42 /facilities/<type> directories on nycgovparks.org (common columns Name, Location, Accessible, # of Courts/Fields, Surface, In/Outdoor, Phone) with the 'Athletic Facilities' Open Data dataset (qnem-b8re, 45 columns) and the per-type directory datasets. The many per-sport boolean columns in Open Data are flattened here into the 'activities' array.",
  "type": "object",
  "x-source": {
    "website": "https://www.nycgovparks.org/facilities",
    "opendata": ["https://data.cityofnewyork.us/d/qnem-b8re", "https://data.cityofnewyork.us/d/y5rm-wagw"]
  },
  "properties": {
    "id": { "type": "string", "description": "Facility identifier (e.g. GISPROPNUM + FIELD_NUMBER, or directory row id)." },
    "park": { "$ref": "_common.json#/$defs/ParkReference" },
    "name": { "type": ["string", "null"], "description": "Facility name where named (Name)." },
    "facilityType": {
      "type": "string",
      "description": "Primary facility type — the /facilities/<type> the record came from.",
      "enum": [
        "tennis", "basketball", "handball", "baseball", "softball", "soccer", "football",
        "cricket", "bocce", "volleyball", "hockey", "running-track", "fitness-equipment",
        "outdoor-pool", "indoor-pool", "spray-shower", "playground", "dog-area", "beach",
        "golf", "skate-park", "ice-skating", "kayak-canoe", "model-aircraft", "recreation-center",
        "nature-center", "historic-house", "media-lab", "pickleball", "barbecue", "fishing",
        "hiking-trail", "bikeway", "restroom", "water-fountain", "boating", "wifi", "zoo",
        "great-tree", "horseback", "food-concession"
      ]
    },
    "activities": {
      "type": "array",
      "description": "Sports/uses supported (flattened from the Open Data per-sport Checkbox columns, e.g. TENNIS, BASKETBALL, HANDBALL, CRICKET, PICKLEBALL, BOCCE).",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "location": { "type": ["string", "null"], "description": "In-park location / cross-streets (Location)." },
    "borough": { "$ref": "_common.json#/$defs/Borough" },
    "count": { "type": ["integer", "null"], "minimum": 0, "description": "Number of courts/fields at this facility (# of Courts / # of Fields)." },
    "surfaceType": { "type": ["string", "null"], "description": "Playing surface (SURFACE_TYPE / Type of Surface), e.g. 'Asphalt', 'Natural Turf', 'Synthetic'." },
    "indoorOutdoor": { "type": ["string", "null"], "enum": ["indoor", "outdoor", null], "description": "In/Outdoor." },
    "lighted": { "type": ["boolean", "null"], "description": "Whether the facility is lit (FIELD_LIGHTED)." },
    "dimensions": { "type": ["string", "null"], "description": "Field/court dimensions (DIMENSIONS)." },
    "poolType": { "type": ["string", "null"], "description": "For pools: Intermediate / Mini / Olympic (POOLTYPE)." },
    "phone": { "type": ["string", "null"], "description": "Contact phone (Phone)." },
    "accessible": { "$ref": "_common.json#/$defs/Accessibility" },
    "featureStatus": {
      "type": ["string", "null"],
      "description": "Operational status (FEATURESTATUS).",
      "enum": ["Open", "Closed", "Seasonal", "Under Construction", null]
    },
    "admin": { "$ref": "_common.json#/$defs/AdminBoundaries" },
    "coordinates": { "$ref": "_common.json#/$defs/Coordinates" },
    "url": { "type": ["string", "null"], "format": "uri" }
  },
  "required": ["facilityType", "park"],
  "additionalProperties": false
}
