{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/nyc/main/nycgovparks.org/schemas/event.json",
  "title": "Event",
  "description": "A public event or program at a NYC park. Canonical schema reconciling the /events calendar on nycgovparks.org with the normalized 'NYC Parks Events Listing' Open Data set (Event Listing fudw-fgrp + Locations, Categories, Images, Organizers, Links).",
  "type": "object",
  "x-source": {
    "website": "https://www.nycgovparks.org/events",
    "opendata": "https://data.cityofnewyork.us/d/fudw-fgrp"
  },
  "properties": {
    "eventId": { "type": ["integer", "string"], "description": "Event identifier (event_id)." },
    "title": { "type": "string", "description": "Event title (title)." },
    "snippet": { "type": ["string", "null"], "description": "Short teaser (snippet)." },
    "description": { "type": ["string", "null"], "description": "Full description (description)." },
    "date": { "type": ["string", "null"], "format": "date", "description": "Event date (date)." },
    "startTime": { "type": ["string", "null"], "description": "Start time as published (start_time)." },
    "endTime": { "type": ["string", "null"], "description": "End time as published (end_time)." },
    "locationDescription": { "type": ["string", "null"], "description": "Where in the park (location_description)." },
    "park": { "$ref": "_common.json#/$defs/ParkReference" },
    "borough": { "$ref": "_common.json#/$defs/Borough" },
    "categories": {
      "type": "array",
      "description": "Event categories (from Event Categories dataset).",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "cost": {
      "type": "object",
      "description": "Cost information (cost_free, cost_description).",
      "properties": {
        "free": { "type": ["boolean", "null"] },
        "description": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "mustSee": { "type": ["boolean", "null"], "description": "Featured/highlighted flag (must_see)." },
    "organizer": { "type": ["string", "null"], "description": "Organizing entity (from Event Organizers dataset)." },
    "url": { "type": ["string", "null"], "format": "uri", "description": "Event detail URL (url)." },
    "phone": { "type": ["string", "null"] },
    "email": { "type": ["string", "null"], "format": "email" }
  },
  "required": ["eventId", "title"],
  "additionalProperties": false
}
