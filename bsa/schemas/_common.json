{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/nyc/main/bsa/schemas/_common.json",
  "title": "BSA — Shared Definitions",
  "description": "Reusable JSON Schema definitions shared across NYC Board of Standards & Appeals (BSA) object schemas. Reconciles fields common to the BSA Open Data datasets (data.cityofnewyork.us), nyc.gov/site/bsa, and the PDF application forms. Includes the NYC geography/property spine (BBL, BIN, block/lot, zoning district) and BSA's calendar-number key.",
  "$defs": {
    "Borough": {
      "type": "string",
      "enum": ["Manhattan", "Bronx", "Brooklyn", "Queens", "Staten Island"]
    },
    "Coordinates": {
      "type": "object",
      "description": "WGS84 point (Open Data LATITUDE / LONGITUDE).",
      "properties": {
        "latitude": { "type": "number", "minimum": -90, "maximum": 90 },
        "longitude": { "type": "number", "minimum": -180, "maximum": 180 }
      },
      "required": ["latitude", "longitude"],
      "additionalProperties": false
    },
    "Geography": {
      "type": "object",
      "description": "The NYC geography spine shared across BSA datasets — the join keys back to the rest of city government.",
      "properties": {
        "borough": { "$ref": "#/$defs/Borough" },
        "communityBoard": { "type": ["string", "integer", "null"], "description": "Community District / Board ('Community Board' / 'Community Districts')." },
        "councilDistrict": { "type": ["integer", "null"], "minimum": 1, "maximum": 51, "description": "NYC Council district ('Council District')." },
        "censusTract": { "type": ["string", "null"], "description": "2020 Census tract ('Census Tract (2020)')." },
        "nta": { "type": ["string", "null"], "description": "Neighborhood Tabulation Area name or code ('Neighborhood Tabulation Area (NTA) (2020)')." },
        "policePrecinct": { "type": ["string", "integer", "null"], "description": "'Police Precincts'." }
      },
      "additionalProperties": false
    },
    "PropertyReference": {
      "type": "object",
      "description": "The NYC property/zoning-lot spine that identifies the premises of a BSA case.",
      "properties": {
        "address": { "type": ["string", "null"], "description": "Full premise address." },
        "streetNumber": { "type": ["string", "null"], "description": "'street_number' / 'PremiseAddressNumber'." },
        "streetName": { "type": ["string", "null"], "description": "'street_name' / 'PremiseAddressStreet'." },
        "borough": { "$ref": "#/$defs/Borough" },
        "boroughCode": { "type": ["string", "integer", "null"], "description": "'borough_code' (1=MN, 2=BX, 3=BK, 4=QN, 5=SI)." },
        "block": { "type": ["string", "null"], "description": "Tax block ('block')." },
        "lot": { "type": ["string", "null"], "description": "Tax lot ('lot' / 'lots')." },
        "bbl": { "type": ["string", "null"], "description": "Borough-Block-Lot ('BBL')." },
        "bin": { "type": ["string", "null"], "description": "Building Identification Number ('BIN')." },
        "postcode": { "type": ["string", "null"], "description": "'Postcode' / ZIP." },
        "zoningDistrict": { "type": ["string", "null"], "description": "Zoning district designation ('zoning_district')." }
      },
      "additionalProperties": false
    },
    "CalendarReference": {
      "type": "object",
      "description": "A reference to a BSA case by its calendar number — the Board's primary case key (e.g. '2024-26-BZ', '246-98-BZII', '6-16-S').",
      "properties": {
        "calendar": { "type": "string", "description": "Full calendar number ('calendar' / 'CalendarNumber')." },
        "number": { "type": ["string", "null"], "description": "Sequence number within the year ('C1')." },
        "year": { "type": ["string", "null"], "description": "Filing year, two- or four-digit ('C2')." },
        "suffix": { "type": ["string", "null"], "description": "Application-type suffix ('C3'), e.g. BZ, BZY, A, S, SOC." }
      },
      "required": ["calendar"],
      "additionalProperties": false
    },
    "ApplicationType": {
      "type": "string",
      "description": "BSA application/case type. BZ = variance/special-permit (Board Zoning); BZY = extension of time / vested rights; SOC = Special Order Calendar (amendment/extension of a prior grant); Appeal = appeal of a DOB/agency determination; S = legacy special-permit calendar suffix.",
      "enum": ["BZ", "BZY", "SOC", "Appeal", "S", "Compliance", "Other"]
    },
    "CaseStatus": {
      "type": ["string", "null"],
      "description": "Disposition of a decided BSA case.",
      "enum": ["Granted", "Denied", "Withdrawn", "Dismissed", "Pending", "Decision", null]
    }
  }
}
