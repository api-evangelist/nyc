  "tools": [
    {
      "name": "find_applications",
      "title": "Find Applications",
      "description": "Search BSA applications / cases by borough, application type, status, zoning district, council district, BBL, date range, and/or free text.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "borough": {
            "type": "string",
            "enum": [
              "Manhattan",
              "Bronx",
              "Brooklyn",
              "Queens",
              "Staten Island"
            ]
          },
          "application": {
            "type": "string",
            "enum": [
              "BZ",
              "BZY",
              "SOC",
              "Appeal",
              "S",
              "Compliance",
              "Other"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "Granted",
              "Denied",
              "Withdrawn",
              "Dismissed",
              "Pending"
            ]
          },
          "zoningDistrict": {
            "type": "string"
          },
          "councilDistrict": {
            "type": "integer",
            "minimum": 1,
            "maximum": 51
          },
          "bbl": {
            "type": "string"
          },
          "from": {
            "type": "string",
            "format": "date"
          },
          "to": {
            "type": "string",
            "format": "date"
          },
          "q": {
            "type": "string"
          },
          "page": {
            "type": "integer",
            "minimum": 1,
            "default": 1
          },
          "perPage": {
            "type": "integer",
            "minimum": 1,
            "maximum": 200,
            "default": 50
          }
        }
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "../schemas/application.json"
            }
          }
        }
