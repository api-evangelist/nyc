    "tools": {
      "listChanged": false
    },
    "prompts": {
      "listChanged": false
    },
    "resources": {
      "listChanged": false,
      "subscribe": false
    }
  },
  "tools": [
    {
      "name": "find_developments",
      "title": "Find Developments",
      "description": "Search NYCHA public housing developments by borough, program, senior status, council district, and/or free text.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "borough": {
            "type": "string",
            "enum": [
              "Manhattan",
              "Bronx",
              "Brooklyn",
              "Queens",
              "Staten Island"
            ]
          },
          "program": {
            "type": "string"
          },
          "seniorDevelopment": {
            "type": "boolean"
          },
          "councilDistrict": {
            "type": "integer",
            "minimum": 1,
            "maximum": 51
          },
          "q": {
            "type": "string"
          },
          "page": {
            "type": "integer",
            "minimum": 1,
            "default": 1
          },
          "perPage": {
            "type": "integer",
            "minimum": 1,
            "maximum": 200,
            "default": 50
          }
        }
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "../schemas/development.json"
            }
          }
        }
      },
      "annotations": {
