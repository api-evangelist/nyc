{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/nyc/main/dvs/schemas/veteran-owned-business.json",
  "title": "VeteranOwnedBusiness",
  "description": "A veteran-owned business in the DVS directory — a geocoded listing carrying the full NYC geography spine and certifications. Canonical schema reconciling 'NYC Veteran Owned Businesses' (ybdk-jmnn, 27 columns). Keyed on DVS_RES_ID.",
  "type": "object",
  "x-source": {
    "opendata": "https://data.cityofnewyork.us/d/ybdk-jmnn"
  },
  "properties": {
    "dvsResId": { "type": ["string", "null"], "description": "DVS resource identifier ('DVS_RES_ID') — primary key." },
    "name": { "type": "string", "description": "Business name ('Name')." },
    "service": { "type": ["string", "null"], "description": "Business service / category ('Service')." },
    "serviceDetails": { "type": ["string", "null"], "description": "Free-text description ('Service Details')." },
    "certifications": { "type": ["string", "null"], "description": "Business certifications ('Certifications', e.g. SDVOB / MWBE)." },
    "phoneNumber": { "type": ["string", "null"], "description": "'Phone Number'." },
    "email": { "type": ["string", "null"], "format": "email", "description": "'Email Address'." },
    "website": { "type": ["string", "null"], "description": "'Website'." },
    "address": { "type": ["string", "null"], "description": "'Address'." },
    "city": { "type": ["string", "null"], "description": "'City'." },
    "state": { "type": ["string", "null"], "description": "'State'." },
    "postcode": { "type": ["string", "null"], "description": "'Postcode'." },
    "geography": { "$ref": "_common.json#/$defs/Geography" },
    "coordinates": { "$ref": "_common.json#/$defs/Coordinates" }
  },
  "required": ["name"],
  "additionalProperties": false
}
