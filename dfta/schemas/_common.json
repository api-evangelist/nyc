{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/nyc/main/dfta/schemas/_common.json",
  "title": "NYC Aging (DFTA) — Shared Definitions",
  "description": "Reusable JSON Schema definitions shared across NYC Department for the Aging (DFTA / 'NYC Aging') object schemas. Reconciles fields common to the DFTA Open Data datasets (data.cityofnewyork.us), nyc.gov/site/dfta, and the Aging Connect information-and-referral intake. Includes the NYC geography spine and DFTA's own contracted-provider key (DFTA ID) and provider-type vocabulary.",
  "$defs": {
    "Borough": {
      "type": "string",
      "enum": ["Manhattan", "Bronx", "Brooklyn", "Queens", "Staten Island"]
    },
    "Coordinates": {
      "type": "object",
      "description": "WGS84 point (Open Data Latitude / Longitude).",
      "properties": {
        "latitude": { "type": "number", "minimum": -90, "maximum": 90 },
        "longitude": { "type": "number", "minimum": -180, "maximum": 180 }
      },
      "required": ["latitude", "longitude"],
      "additionalProperties": false
    },
    "Geography": {
      "type": "object",
      "description": "The NYC geography spine shared across DFTA datasets — the join keys back to the rest of city government.",
      "properties": {
        "borough": { "$ref": "#/$defs/Borough" },
        "communityBoard": { "type": ["string", "integer", "null"], "description": "Community District / Board ('Community Board' / 'Community District')." },
        "councilDistrict": { "type": ["integer", "null"], "minimum": 1, "maximum": 51, "description": "NYC Council district ('Council District' / 'City Council District')." },
        "censusTract": { "type": ["string", "null"], "description": "2020 Census tract ('Census Tract (2020)' / 'Census Tract')." },
        "nta": { "type": ["string", "null"], "description": "Neighborhood Tabulation Area name or code ('Neighborhood Tabulation Area (NTA) (2020)' / 'NTA')." },
        "bbl": { "type": ["string", "null"], "description": "Borough-Block-Lot ('BBL')." },
        "bin": { "type": ["string", "null"], "description": "Building Identification Number ('BIN')." },
        "policePrecinct": { "type": ["string", "integer", "null"], "description": "Police precinct ('Police Precincts')." }
      },
      "additionalProperties": false
    },
    "WeeklyHours": {
      "type": "object",
      "description": "Open/close times per day of week, as carried by the provider directories ('MonHourOpen'/'MonHourClose', etc.).",
      "properties": {
        "monOpen": { "type": ["string", "null"] },
        "monClose": { "type": ["string", "null"] },
        "tueOpen": { "type": ["string", "null"] },
        "tueClose": { "type": ["string", "null"] },
        "wedOpen": { "type": ["string", "null"] },
        "wedClose": { "type": ["string", "null"] },
        "thuOpen": { "type": ["string", "null"] },
        "thuClose": { "type": ["string", "null"] },
        "friOpen": { "type": ["string", "null"] },
        "friClose": { "type": ["string", "null"] },
        "satOpen": { "type": ["string", "null"] },
        "satClose": { "type": ["string", "null"] },
        "sunOpen": { "type": ["string", "null"] },
        "sunClose": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "ProviderType": {
      "type": ["string", "null"],
      "description": "DFTA contracted-service / provider category ('ProviderType'). Values from the All Contracted Providers dataset.",
      "enum": [
        "OLDER ADULT CENTER CONTRACTS",
        "SOCIAL ADULT DAY CARE",
        "CASE MANAGEMENT SERVICES CONTRACTS",
        "HOME DELIVERED MEAL SERVICE CONTRACTS",
        "CITY MEALS ADMINISTRATIVE SERVICES CONTRACTS",
        "CAREGIVER SERVICES CONTRACTS",
        "HOMECARE SERVICES CONTRACTS",
        "ELDER ABUSE SERVICES CONTRACTS",
        "GERIATRIC MENTAL HEALTH SERVICES CONTRACTS",
        "LEGAL SERVICES CONTRACTS",
        "NATURALLY OCCURING RETIREMENT COMMUNITY CONTRACTS",
        "NEW YORK CONNECTS CONTRACTS",
        "TRANSPORTATION SERVICES CONTRACTS",
        "OTHER",
        null
      ]
    },
    "DftaProviderReference": {
      "type": "object",
      "description": "A reference to a DFTA-funded provider/program by its DFTA ID and sponsor.",
      "properties": {
        "dftaId": { "type": ["string", "null"], "description": "DFTA contract/program identifier ('DFTA ID' / 'DFTA_ID' / 'dftaid') — NYC Aging's primary provider key." },
        "programName": { "type": ["string", "null"], "description": "Program / site name ('ProgramName' / 'Program Name' / 'Site Name')." },
        "sponsorName": { "type": ["string", "null"], "description": "Contracted sponsor / vendor ('SponsorName' / 'Sponsor/Vendor')." },
        "providerType": { "$ref": "#/$defs/ProviderType" }
      },
      "additionalProperties": false
    }
  }
}
