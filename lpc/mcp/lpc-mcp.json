      "listChanged": false
    },
    "prompts": {
      "listChanged": false
    },
    "resources": {
      "listChanged": false,
      "subscribe": false
    }
  },
  "tools": [
    {
      "name": "find_landmarks",
      "title": "Find Landmarks",
      "description": "Search NYC landmark designations (individual, interior, scenic) by borough, type, site status, historic district, BBL, and/or free text.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "borough": {
            "type": "string",
            "enum": [
              "Manhattan",
              "Bronx",
              "Brooklyn",
              "Queens",
              "Staten Island"
            ]
          },
          "landmarkType": {
            "type": "string",
            "enum": [
              "Individual Landmark",
              "Interior Landmark",
              "Scenic Landmark",
              "Historic District",
              "Historic District Extension"
            ]
          },
          "siteStatus": {
            "type": "string"
          },
          "historicDistrict": {
            "type": "string"
          },
          "bbl": {
            "type": "string"
          },
          "q": {
            "type": "string"
          },
          "page": {
            "type": "integer",
            "minimum": 1,
            "default": 1
          },
          "perPage": {
            "type": "integer",
            "minimum": 1,
            "maximum": 200,
            "default": 50
          }
        }
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "../schemas/landmark.json"
            }
          }
        }
      },
      "annotations": {
        "readOnlyHint": true,
        "openWorldHint": true
      },
      "x-openapi-operation": "listLandmarks",
      "x-agent-skill": "look-up-a-property-or-place"
    },
    {
      "name": "get_landmark",
      "title": "Get Landmark",
