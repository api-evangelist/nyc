  "x-artifact": {
    "kind": "mcp-server-definition",
    "designFirst": true,
    "deployed": false,
    "note": "Design-first artifact only \u2014 describes the MCP tool surface, not a running server. Tool input/output schemas $ref the same object schemas as the OpenAPI; each tool maps to an OpenAPI operationId. Surfaces LPC's open landmark data (landmarks, designated buildings, historic districts, designation reports, permit history, violations) bound under one LP_NUMBER-keyed model, and adds file_permit_application \u2014 the net-new write workflow locked today inside the Salesforce Portico portal.",
    "openapi": "../openapi/lpc.yaml",
    "schemas": "../schemas/"
  },
  "server": {
    "name": "io.nyc.lpc",
    "title": "NYC Landmarks Preservation Commission (LPC)",
    "version": "0.1.0",
    "description": "Agent-native access to the NYC Landmarks Preservation Commission \u2014 individual/interior/scenic landmarks, the designated-building database (architect, style, materials, dates), historic districts, designation and archaeology reports, issued permit history, and landmark violations from NYC Open Data, plus the net-new ability to file a landmark permit application (Certificate of Appropriateness / No Effect) that today lives only in the Salesforce Portico portal.",
    "instructions": "Use find_landmarks / get_landmark (and get_landmark_buildings) to locate designations by borough, type, historic district, or LP number and drill into their buildings. find_buildings searches the architectural building database by architect, style, or lot. find_historic_districts covers area designations. find_designation_reports returns designation and archaeology reports. find_permits searches the OPEN, issued permit history (Certificates of Appropriateness / No Effect). find_violations covers landmark complaints and violations. file_permit_application (net-new) files a new LPC permit application; it requires an authenticated applicant and mutates state \u2014 confirm the property (address/BBL/LP number), permit type, and scope of work with the user before submitting, and note that Certificate of Appropriateness filings go to a public hearing."
  },
