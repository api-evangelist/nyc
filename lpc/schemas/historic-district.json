{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/nyc/main/lpc/schemas/historic-district.json",
  "title": "HistoricDistrict",
  "description": "A NYC historic district — an area designation covering many buildings. Canonical schema reconciling the 'Historic Districts' dataset (skyk-mpzq, 15 columns) and its map twin (xbvj-gfnw). Keyed on LP_NUMBER.",
  "type": "object",
  "x-source": {
    "opendata": "https://data.cityofnewyork.us/d/skyk-mpzq",
    "opendata_map": "https://data.cityofnewyork.us/d/xbvj-gfnw"
  },
  "properties": {
    "lpNumber": { "type": "string", "description": "LPC designation number ('LP_NUMBER') — primary key." },
    "landmarkName": { "type": ["string", "null"], "description": "District name ('LM_NAME')." },
    "borough": { "$ref": "_common.json#/$defs/Borough" },
    "siteStatus": { "$ref": "_common.json#/$defs/SiteStatus" },
    "extension": { "type": ["boolean", "string", "null"], "description": "'EXTENSION' — flags a historic district extension." },
    "mostCurrent": { "type": ["boolean", "string", "null"], "description": "'MOST_CURRENT'." },
    "lastAction": { "type": ["string", "null"], "description": "'LAST_ACTION'." },
    "actionNotes": { "type": ["string", "null"], "description": "'ACTION_NOTES'." },
    "calendaredDate": { "type": ["string", "null"], "format": "date", "description": "'CALEN_DATE'." },
    "publicHearingDate": { "type": ["string", "null"], "description": "'PUBLIC_HEARING'." },
    "otherHearings": { "type": ["string", "null"], "description": "'OTHER_HEARINGS'." },
    "designationDate": { "type": ["string", "null"], "format": "date", "description": "'DESIG_DATE'." },
    "shapeArea": { "type": ["number", "null"], "description": "'Shape_Area' — polygon area." },
    "shapeLength": { "type": ["number", "null"], "description": "'Shape_Leng' — polygon perimeter." }
  },
  "required": ["lpNumber"],
  "additionalProperties": false
}
