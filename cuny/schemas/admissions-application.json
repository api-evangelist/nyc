{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/nyc/main/cuny/schemas/admissions-application.json",
  "title": "AdmissionsApplication",
  "description": "A CUNY admissions application (the 'CUNY Application' / Apply to CUNY flow) — the everyday prospective-student transaction. NET-NEW: there is NO public API and NO Open Data twin for applications; today applicants create, submit, and track a single application to up to several campuses only inside CUNYfirst (Oracle PeopleSoft Campus Solutions) via the guest self-service screens. This schema serves both the read surface (list/get an applicant's own applications) and the write surface (submit an application).",
  "type": "object",
  "x-source": {
    "portal": "https://www.cuny.edu/admissions/undergraduate/apply/cuny-application/",
    "sis": "https://cssa.cunyfirst.cuny.edu/psc/cnycsprd/GUEST/SA/c/CU_E1385_CNSLR_FL.GBL",
    "opendata": null,
    "opendata_gap": true
  },
  "properties": {
    "applicationId": {
      "type": ["string", "null"],
      "description": "Server-assigned application / CUNYfirst applicant number. Omit on create; returned on the created resource.",
      "readOnly": true
    },
    "status": {
      "type": ["string", "null"],
      "enum": ["Draft", "Submitted", "Under Review", "Admitted", "Waitlisted", "Denied", "Deposit Paid", "Withdrawn", null],
      "description": "Lifecycle status. Set by CUNY, not the applicant.",
      "readOnly": true
    },
    "applicantType": {
      "type": "string",
      "description": "Kind of applicant.",
      "enum": ["Freshman", "Transfer", "Graduate", "Non-Degree", "Readmit", "International"]
    },
    "admitTerm": { "$ref": "_common.json#/$defs/Term" },
    "applicant": {
      "type": "object",
      "description": "Applicant identity and contact details.",
      "properties": {
        "firstName": { "type": ["string", "null"] },
        "lastName": { "type": ["string", "null"] },
        "dateOfBirth": { "type": ["string", "null"], "format": "date" },
        "email": { "type": ["string", "null"], "format": "email" },
        "phone": { "type": ["string", "null"] },
        "residency": { "type": ["string", "null"], "description": "e.g. NYC Resident, NY State Resident, Out of State, International." }
      },
      "additionalProperties": false
    },
    "campusChoices": {
      "type": "array",
      "description": "Ranked list of colleges applied to (one CUNY Application covers multiple campuses).",
      "items": {
        "type": "object",
        "properties": {
          "campus": { "$ref": "_common.json#/$defs/CampusReference" },
          "program": { "type": ["string", "null"], "description": "Intended major / program name." },
          "rank": { "type": ["integer", "null"], "minimum": 1 }
        },
        "required": ["campus"],
        "additionalProperties": false
      },
      "minItems": 1
    },
    "priorEducation": {
      "type": "array",
      "description": "High schools and prior colleges attended.",
      "items": {
        "type": "object",
        "properties": {
          "institution": { "type": "string" },
          "type": { "type": ["string", "null"], "enum": ["High School", "College", "Other", null] },
          "graduationDate": { "type": ["string", "null"], "format": "date" }
        },
        "required": ["institution"],
        "additionalProperties": false
      }
    },
    "feeWaiverRequested": { "type": "boolean", "default": false, "description": "Whether the applicant requests an application fee waiver." },
    "submittedDate": { "type": ["string", "null"], "format": "date-time", "readOnly": true },
    "decisionDate": { "type": ["string", "null"], "format": "date", "readOnly": true }
  },
  "required": ["applicantType", "campusChoices"],
  "additionalProperties": false
}
