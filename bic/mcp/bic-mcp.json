              "Bronx",
              "Brooklyn",
              "Queens",
              "Staten Island"
            ]
          },
          "applicationType": {
            "type": "string"
          },
          "renewal": {
            "type": "boolean"
          },
          "councilDistrict": {
            "type": "integer",
            "minimum": 1,
            "maximum": 51
          },
          "q": {
