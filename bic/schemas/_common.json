{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/nyc/main/bic/schemas/_common.json",
  "title": "BIC — Shared Definitions",
  "description": "Reusable JSON Schema definitions shared across NYC Business Integrity Commission (BIC) object schemas. Reconciles fields common to the BIC Open Data datasets (data.cityofnewyork.us), nyc.gov/site/bic, and the Salesforce Experience Cloud licensing portal (bicportal.nyc.gov). Includes the NYC geography spine and BIC's own account key (BIC NUMBER).",
  "$defs": {
    "Borough": {
      "type": "string",
      "enum": ["Manhattan", "Bronx", "Brooklyn", "Queens", "Staten Island"]
    },
    "Coordinates": {
      "type": "object",
      "description": "WGS84 point (Open Data LATITUDE / LONGITUDE).",
      "properties": {
        "latitude": { "type": "number", "minimum": -90, "maximum": 90 },
        "longitude": { "type": "number", "minimum": -180, "maximum": 180 }
      },
      "required": ["latitude", "longitude"],
      "additionalProperties": false
    },
    "Geography": {
      "type": "object",
      "description": "The NYC geography spine shared across BIC datasets — the join keys back to the rest of city government.",
      "properties": {
        "borough": { "$ref": "#/$defs/Borough" },
        "boro": { "type": ["string", "null"], "description": "Raw borough field as published ('BORO' / 'BOROUGH')." },
        "communityBoard": { "type": ["string", "integer", "null"], "description": "Community District / Board ('COMMUNITY BOARD')." },
        "councilDistrict": { "type": ["integer", "null"], "minimum": 1, "maximum": 51, "description": "NYC Council district ('COUNCIL DISTRICT')." },
        "censusTract": { "type": ["string", "null"], "description": "Census tract ('CENSUS TRACT')." },
        "nta": { "type": ["string", "null"], "description": "Neighborhood Tabulation Area name or code ('NTA')." },
        "bbl": { "type": ["string", "null"], "description": "Borough-Block-Lot ('BBL')." },
        "bin": { "type": ["string", "null"], "description": "Building Identification Number ('BIN')." }
      },
      "additionalProperties": false
    },
    "Address": {
      "type": "object",
      "description": "A mailing / place-of-business address as carried by BIC datasets.",
      "properties": {
        "address": { "type": ["string", "null"], "description": "Street address ('ADDRESS' / 'STREET')." },
        "city": { "type": ["string", "null"], "description": "'CITY'." },
        "state": { "type": ["string", "null"], "description": "'STATE'." },
        "postcode": { "type": ["string", "null"], "description": "'POSTCODE' / 'ZIP'." }
      },
      "additionalProperties": false
    },
    "AccountReference": {
      "type": "object",
      "description": "A reference to a BIC-regulated business account by its BIC number and names.",
      "properties": {
        "bicNumber": { "type": ["string", "null"], "description": "'BIC NUMBER' — BIC's primary account key for a licensee/registrant/market business." },
        "accountName": { "type": ["string", "null"], "description": "Legal account name ('ACCOUNT NAME')." },
        "tradeName": { "type": ["string", "null"], "description": "Doing-business-as / trade name ('TRADE NAME')." }
      },
      "additionalProperties": false
    },
    "Industry": {
      "type": ["string", "null"],
      "description": "The BIC-regulated industry an account operates in.",
      "enum": ["Trade Waste Hauler", "Trade Waste Broker", "Self Hauler", "Construction & Demolition", "Wholesale Market", "Other", null]
    },
    "ApplicationType": {
      "type": ["string", "null"],
      "description": "Application / credential type ('APPLICATION TYPE'): license, registration, exemption, or renewal.",
      "enum": ["License", "Registration", "Exemption", "Renewal", "Amendment", "Other", null]
    }
  }
}
