{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/nyc/main/bic/schemas/market-business.json",
  "title": "MarketBusiness",
  "description": "A business registered to operate in one of New York City's public wholesale markets (e.g. Hunts Point Produce Market, Hunts Point Meat Market, the Fulton Fish Market). Canonical schema reconciling the 'Wholesale Markets' dataset (87fx-28ei, 26 columns). Keyed on BIC NUMBER; the `market` field names the wholesale market.",
  "type": "object",
  "x-source": {
    "opendata": "https://data.cityofnewyork.us/d/87fx-28ei",
    "site": "https://www.nyc.gov/site/bic/industries/public-wholesale-markets.page"
  },
  "properties": {
    "bicNumber": { "type": "string", "description": "'BIC NUMBER' — primary key." },
    "accountName": { "type": ["string", "null"], "description": "'ACCOUNT NAME'." },
    "tradeName": { "type": ["string", "null"], "description": "'TRADE NAME'." },
    "market": { "type": ["string", "null"], "description": "'MARKET' — the public wholesale market the business operates in (e.g. Hunts Point Produce, Hunts Point Meat, Fulton Fish)." },
    "applicationType": { "$ref": "_common.json#/$defs/ApplicationType" },
    "renewal": { "type": ["boolean", "string", "null"], "description": "'RENEWAL'." },
    "phone": { "type": ["string", "null"], "description": "'PHONE'." },
    "email": { "type": ["string", "null"], "format": "email", "description": "'EMAIL'." },
    "address": { "$ref": "_common.json#/$defs/Address" },
    "geography": { "$ref": "_common.json#/$defs/Geography" },
    "coordinates": { "$ref": "_common.json#/$defs/Coordinates" },
    "effectiveDate": { "type": ["string", "null"], "format": "date", "description": "'EFFECTIVE DATE'." },
    "expirationDate": { "type": ["string", "null"], "format": "date", "description": "'EXPIRATION DATE'." },
    "dispositionDate": { "type": ["string", "null"], "format": "date", "description": "'DISPOSITION DATE'." },
    "created": { "type": ["string", "null"], "format": "date-time", "description": "'CREATED'." },
    "exportDate": { "type": ["string", "null"], "format": "date-time", "description": "'EXPORT DATE' — snapshot timestamp.", "readOnly": true }
  },
  "required": ["bicNumber"],
  "additionalProperties": false
}
