{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/nyc/main/schools.nyc.gov/schemas/school.json",
  "title": "School",
  "description": "A NYC public school. Canonical schema reconciling the /schools/<LocationCode> directory pages on schools.nyc.gov with the DOE Open Data 'School Locations', 'DOE High School Directory' (462 columns) and 'Demographic Snapshot' datasets. Keyed on DBN — the root entity of the domain.",
  "type": "object",
  "x-source": {
    "website": "https://www.schools.nyc.gov/find-a-school",
    "opendata": ["https://data.cityofnewyork.us (DOE School Locations)", "DOE High/Middle/Elementary School Directory", "Demographic Snapshot c7ru-d68s"]
  },
  "properties": {
    "dbn": { "$ref": "_common.json#/$defs/DBN" },
    "locationCode": { "type": ["string", "null"], "description": "ATS/location code used in the schools.nyc.gov URL (e.g. 'KBLK')." },
    "name": { "type": "string", "description": "School name (LocName / School Name)." },
    "schoolType": {
      "type": ["string", "null"],
      "description": "Grade band / type.",
      "enum": ["Early Childhood", "Elementary", "K-8", "Middle", "Junior High-Intermediate-Middle", "High school", "Secondary School", "K-12 all grades", "Transfer School", "District 75 (Special Education)", "YABC", null]
    },
    "gradesServed": {
      "type": "array",
      "description": "Grades the school serves.",
      "items": { "$ref": "_common.json#/$defs/GradeLevel" }
    },
    "district": { "type": ["integer", "null"], "description": "Community school district number (1–32, plus 75/79/84)." },
    "borough": { "$ref": "_common.json#/$defs/Borough" },
    "superintendent": { "type": ["string", "null"] },
    "principal": { "type": ["string", "null"] },
    "address": { "type": ["string", "null"] },
    "zipCode": { "type": ["string", "null"], "pattern": "^\\d{5}$" },
    "phone": { "type": ["string", "null"] },
    "fax": { "type": ["string", "null"] },
    "email": { "type": ["string", "null"], "format": "email" },
    "website": { "type": ["string", "null"], "format": "uri" },
    "totalEnrollment": { "type": ["integer", "null"], "minimum": 0, "description": "From Demographic Snapshot (Total Enrollment)." },
    "programs": {
      "type": "array",
      "description": "Academic/admissions programs offered (esp. from the High School Directory).",
      "items": { "type": "string" }
    },
    "admissionMethods": {
      "type": "array",
      "description": "Admissions methods (Screened, Ed. Opt., Zoned, Open, Specialized, etc.).",
      "items": { "type": "string" }
    },
    "coordinates": { "$ref": "_common.json#/$defs/Coordinates" },
    "admin": { "$ref": "_common.json#/$defs/AdminBoundaries" },
    "url": { "type": ["string", "null"], "format": "uri", "description": "Canonical schools.nyc.gov page." }
  },
  "required": ["dbn", "name"],
  "additionalProperties": false
}
