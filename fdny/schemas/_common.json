{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/nyc/main/fdny/schemas/_common.json",
  "title": "FDNY — Shared Definitions",
  "description": "Reusable JSON Schema definitions shared across Fire Department of the City of New York (FDNY) object schemas. Reconciles fields common to the FDNY Open Data datasets (data.cityofnewyork.us), nyc.gov/site/fdny, and the FDNY Business permitting portal (fires.fdnycloud.org — an Accela Civic Platform application). Includes the NYC geography spine and FDNY's own premises/account keys (BIN, BBL, ACCT_NUM/ACCT_ID).",
  "$defs": {
    "Borough": {
      "type": "string",
      "enum": ["Manhattan", "Bronx", "Brooklyn", "Queens", "Staten Island"]
    },
    "Coordinates": {
      "type": "object",
      "description": "WGS84 point (Open Data LATITUDE / LONGITUDE).",
      "properties": {
        "latitude": { "type": "number", "minimum": -90, "maximum": 90 },
        "longitude": { "type": "number", "minimum": -180, "maximum": 180 }
      },
      "required": ["latitude", "longitude"],
      "additionalProperties": false
    },
    "Geography": {
      "type": "object",
      "description": "The NYC geography spine shared across FDNY datasets — the join keys back to the rest of city government.",
      "properties": {
        "borough": { "$ref": "#/$defs/Borough" },
        "communityBoard": { "type": ["string", "integer", "null"], "description": "Community District / Board ('COMMUNITY BOARD' / 'COMMUNITYDISTRICT')." },
        "councilDistrict": { "type": ["integer", "null"], "minimum": 1, "maximum": 51, "description": "NYC Council district ('COUNCIL DISTRICT' / 'CITYCOUNCILDISTRICT')." },
        "censusTract": { "type": ["string", "null"], "description": "Census tract ('CENSUS TRACT')." },
        "nta": { "type": ["string", "null"], "description": "Neighborhood Tabulation Area name or code ('NTA')." },
        "bbl": { "type": ["string", "null"], "description": "Borough-Block-Lot ('BBL')." },
        "bin": { "type": ["string", "null"], "description": "Building Identification Number ('BIN' / 'BLDG_CURRENT_BIN_FK')." },
        "postcode": { "type": ["string", "null"], "description": "ZIP / postcode ('POSTCODE' / 'ZIPCODE' / 'ZIP')." },
        "policePrecinct": { "type": ["string", "integer", "null"], "description": "NYPD precinct ('POLICEPRECINCT') carried by dispatch/inspection datasets." },
        "congressionalDistrict": { "type": ["string", "integer", "null"], "description": "US congressional district ('CONGRESSIONALDISTRICT')." }
      },
      "additionalProperties": false
    },
    "PremisesReference": {
      "type": "object",
      "description": "A reference to an inspected/regulated premises as it appears across Bureau of Fire Prevention datasets and FDNY Business — the account and building keys.",
      "properties": {
        "premisesAddress": { "type": ["string", "null"], "description": "Premises address ('PREM_ADDR' / 'AKA_ADDRESS')." },
        "houseNumber": { "type": ["string", "null"], "description": "'NUMBER'." },
        "street": { "type": ["string", "null"], "description": "'STREET'." },
        "acctNum": { "type": ["string", "null"], "description": "FDNY account number ('ACCT_NUM') — the Bureau of Fire Prevention premises account." },
        "acctId": { "type": ["string", "null"], "description": "FDNY internal account id ('ACCT_ID')." },
        "ownerName": { "type": ["string", "null"], "description": "'OWNER_NAME' / 'ACCT_OWNER'." },
        "bin": { "type": ["string", "null"], "description": "Building Identification Number ('BIN')." },
        "bbl": { "type": ["string", "null"], "description": "Borough-Block-Lot ('BBL')." }
      },
      "additionalProperties": false
    },
    "Service": {
      "type": "string",
      "description": "Which FDNY response line an incident belongs to.",
      "enum": ["Fire", "EMS"]
    }
  }
}
