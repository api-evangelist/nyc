{
  "x-artifact": {
    "kind": "mcp-server-definition",
    "designFirst": true,
    "deployed": false,
    "note": "Design-first artifact only \u2014 describes the MCP tool surface, not a running server. Tool input/output schemas $ref the same object schemas as the OpenAPI; each tool maps to an OpenAPI operationId. Surfaces FDNY's open reference/operational data (firehouses, fire & EMS incident dispatch, inspections, violations, certificates of fitness) and adds apply_for_permit \u2014 the net-new write workflow locked today inside the rented FDNY Business (Accela Civic Platform) portal.",
    "openapi": "../openapi/fdny.yaml",
    "schemas": "../schemas/"
  },
  "server": {
    "name": "io.nyc.fdny",
    "title": "NYC Fire Department (FDNY)",
    "version": "0.1.0",
    "description": "Agent-native access to the Fire Department of the City of New York \u2014 firehouses, fire and EMS incident dispatch, Bureau of Fire Prevention inspections, active violation orders, and certificates of fitness from NYC Open Data, plus the net-new ability to apply for and track a fire permit that today lives only in the rented FDNY Business (Accela) portal.",
    "instructions": "Use find_firehouses / get_firehouse to locate fire stations by borough or council district. find_incidents searches fire and EMS incident dispatch records (set service=Fire or service=EMS); get_incident fetches one. find_inspections covers Bureau of Fire Prevention, risk-based (RBIS), and mandatory fire-company inspections by premises (BIN/BBL); find_violations returns active violation orders; find_certificates_of_fitness returns certificates by type, premises, or holder. apply_for_permit (net-new) submits an FDNY fire permit / Certificate of Operation / inspection request; it requires an authenticated applicant and mutates state \u2014 confirm the premises, permit type, and description with the user before submitting. list_my_permit_applications and get_permit_application read the applicant's own filings."
  },
  "capabilities": {
    "tools": {
      "listChanged": false
    },
    "prompts": {
      "listChanged": false
    },
    "resources": {
      "listChanged": false,
      "subscribe": false
    }
  },
  "tools": [
    {
      "name": "find_firehouses",
      "title": "Find Firehouses",
      "description": "Search FDNY firehouses / fire stations by borough, council district, and/or free text.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "borough": {
            "type": "string",
            "enum": [
              "Manhattan",
              "Bronx",
              "Brooklyn",
              "Queens",
              "Staten Island"
            ]
          },
          "councilDistrict": {
            "type": "integer",
            "minimum": 1,
            "maximum": 51
          },
          "q": {
            "type": "string"
          },
          "page": {
            "type": "integer",
            "minimum": 1,
            "default": 1
          },
          "perPage": {
            "type": "integer",
            "minimum": 1,
            "maximum": 200,
            "default": 50
          }
        }
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "../schemas/firehouse.json"
            }
          }
        }
      },
      "annotations": {
        "readOnlyHint": true,
        "openWorldHint": true
      },
      "x-openapi-operation": "listFirehouses",
      "x-agent-skill": "search-city-data-and-records"
    },
    {
