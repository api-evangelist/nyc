  "server": {
    "name": "io.nyc.dcas",
    "title": "NYC Citywide Administrative Services (DCAS)",
    "version": "0.1.0",
    "description": "Agent-native access to the NYC Department of Citywide Administrative Services \u2014 citywide job postings, civil-service titles, eligible lists, the annual exam schedule, DCAS-managed public buildings and their energy, and the municipal fleet from NYC Open Data, plus the net-new ability to register for a civil-service exam that today lives only in the OASys / City Jobs application layer.",
    "instructions": "Use find_job_postings / get_job_posting to search citywide openings brokered by DCAS. find_civil_service_titles / get_civil_service_title cover the classification catalog (salary bands, unions). find_eligible_list_entries searches the exam-score-ordered lists DCAS certifies to agencies (active, terminated, certified). find_exam_schedule / get_exam return the annual civil-service examination calendar and application windows; register_for_exam (net-new) files an application for an exam \u2014 it requires an authenticated candidate and mutates state, so confirm the exam number and applicant details before submitting and surface any veteran/residency credit, fee waiver, or accommodation requested. find_buildings covers DCAS-managed public buildings and energy; find_fleet covers the municipal fleet (daily service, auctions, fuel efficiency, EV stations)."
  },
  "capabilities": {
    "tools": {
      "listChanged": false
    }
  },
  "tools": [
    {
      "name": "find_job_postings",
      "title": "Find Job Postings",
      "description": "Search citywide job postings brokered by DCAS by agency, category, career level, posting type, title code, and/or free text.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "agency": {
            "type": "string"
          },
          "jobCategory": {
            "type": "string"
          },
          "careerLevel": {
            "type": "string"
          },
          "postingType": {
            "type": "string",
            "enum": [
              "Internal",
              "External"
            ]
          },
          "titleCode": {
            "type": "string"
          },
          "q": {
            "type": "string"
          },
          "page": {
            "type": "integer",
            "minimum": 1,
            "default": 1
          },
          "perPage": {
            "type": "integer",
            "minimum": 1,
            "maximum": 200,
            "default": 50
          }
        }
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "../schemas/job-posting.json"
            }
          }
        }
      },
      "annotations": {
        "readOnlyHint": true,
        "openWorldHint": true
      },
      "x-openapi-operation": "listJobPostings",
      "x-agent-skill": "search-city-data-and-records"
    },
    {
