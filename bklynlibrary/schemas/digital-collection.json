{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/nyc/main/bklynlibrary/schemas/digital-collection.json",
  "title": "DigitalCollection",
  "description": "A Brooklyn Public Library digital collection item — a digitized asset, feature collection, or archival finding aid from BPL's Center for Brooklyn History and digital collections. Canonical schema reconciling BPL's public Drupal JSON:API 'node--digital_asset' (field_da_creator, field_da_id, field_da_mp3, field_da_place), 'node--feature_collection_digcoll', and 'node--finding_aid'.",
  "type": "object",
  "x-source": {
    "jsonapi_digital_asset": "https://www.bklynlibrary.org/jsonapi/node/digital_asset",
    "jsonapi_feature_collection": "https://www.bklynlibrary.org/jsonapi/node/feature_collection_digcoll",
    "jsonapi_finding_aid": "https://www.bklynlibrary.org/jsonapi/node/finding_aid"
  },
  "properties": {
    "id": { "type": ["string", "null"], "description": "Asset id ('field_da_id') or node id." },
    "kind": {
      "type": ["string", "null"],
      "description": "Which digital-collections type this record is.",
      "enum": ["DigitalAsset", "FeatureCollection", "FindingAid", null]
    },
    "title": { "type": "string", "description": "Asset title ('title')." },
    "alternativeTitle": { "type": ["string", "null"], "description": "'field_da_alt_title'." },
    "creator": { "type": ["string", "null"], "description": "'field_da_creator'." },
    "description": { "type": ["string", "null"], "description": "Descriptive note ('body' / 'field_da_note')." },
    "place": { "type": ["string", "null"], "description": "Place depicted / of origin ('field_da_place')." },
    "audioUrl": { "type": ["string", "null"], "format": "uri", "description": "Audio derivative ('field_da_mp3')." },
    "coordinates": { "$ref": "_common.json#/$defs/Coordinates" }
  },
  "required": ["title"],
  "additionalProperties": false
}
