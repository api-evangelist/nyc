{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/nyc/main/bklynlibrary/schemas/library-card.json",
  "title": "LibraryCard",
  "description": "A Brooklyn Public Library patron account / library card, and the application to obtain one. Reading a card (status, expiry, fines) lives only inside the BiblioCommons patron account; applying for a card today is a Drupal webform (webform_submission--library_card_access, the /card flow) with no owned public API. This schema serves both the read surface (the patron's own card) and the LibraryCardApplication write surface.",
  "type": "object",
  "x-source": {
    "application_webform": "https://www.bklynlibrary.org/card/",
    "account": "https://bklynlibrary.bibliocommons.com/user/myaccount",
    "opendata": null,
    "opendata_gap": true
  },
  "properties": {
    "cardNumber": { "type": ["string", "null"], "description": "Library card / barcode number. Omit on application; returned on the created account.", "readOnly": true },
    "status": {
      "type": ["string", "null"],
      "enum": ["Pending", "Active", "Expired", "Blocked", "Temporary", null],
      "description": "Account status. Set by BPL, not the applicant.",
      "readOnly": true
    },
    "firstName": { "type": "string", "description": "Applicant first name." },
    "lastName": { "type": "string", "description": "Applicant last name." },
    "dateOfBirth": { "type": ["string", "null"], "format": "date" },
    "email": { "type": ["string", "null"], "format": "email" },
    "phone": { "type": ["string", "null"] },
    "address": { "$ref": "_common.json#/$defs/Address" },
    "residency": {
      "type": ["string", "null"],
      "enum": ["Brooklyn", "NYC (other borough)", "New York State", "Out of state", null],
      "description": "Residency basis for eligibility."
    },
    "homeBranch": { "$ref": "_common.json#/$defs/BranchReference" },
    "expirationDate": { "type": ["string", "null"], "format": "date", "readOnly": true },
    "finesOwed": { "type": ["number", "null"], "description": "Outstanding fines/fees on the account.", "readOnly": true },
    "createdDate": { "type": ["string", "null"], "format": "date-time", "readOnly": true }
  },
  "required": ["firstName", "lastName"],
  "additionalProperties": false
}
