  "server": {
    "name": "io.nyc.tlc",
    "title": "NYC Taxi & Limousine Commission",
    "version": "0.1.0",
    "description": "Agent-native access to the NYC Taxi & Limousine Commission \u2014 trip records, licensed vehicles and drivers, FHV bases, taxi zones, and inspections. Turns the batch-only TLC Trip Record parquet files and flat NYC Open Data license snapshots into a live queryable surface; adds a net-new TLC license application.",
    "instructions": "Use find_trip_records for yellow/green/FHV trip history (filter by service type, taxi zone, and date). find_vehicles / get_vehicle and find_drivers / get_driver look up TLC-licensed vehicles and drivers by license number. find_bases covers FHV/SHL dispatch bases. find_taxi_zones resolves the PULocationID/DOLocationID codes that trip records use. find_inspections lists scheduled medallion inspections. apply_for_license (net-new) submits a TLC driver/vehicle license application and requires an authenticated user and mutates state \u2014 confirm details with the user before submitting; get_application_status tracks it."
  },
  "capabilities": {
    "tools": {
      "listChanged": false
    },
    "prompts": {
      "listChanged": false
    },
    "resources": {
      "listChanged": false,
      "subscribe": false
    }
  },
  "tools": [
    {
      "name": "find_trip_records",
      "title": "Find Trip Records",
      "description": "Search taxi & for-hire trip records by service type, pickup/drop-off taxi zone, and date range. Fronts the TLC Trip Record parquet files and Open Data snapshots.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "serviceType": {
            "type": "string",
            "enum": [
              "yellow",
              "green",
              "fhv",
              "fhvhv"
            ]
          },
          "pickupZone": {
            "type": "integer",
            "minimum": 1,
            "maximum": 265
          },
          "dropoffZone": {
            "type": "integer",
            "minimum": 1,
            "maximum": 265
          },
          "from": {
            "type": "string",
            "format": "date-time"
          },
          "to": {
            "type": "string",
            "format": "date-time"
          },
          "page": {
            "type": "integer",
            "minimum": 1,
            "default": 1
          },
          "perPage": {
            "type": "integer",
            "minimum": 1,
            "maximum": 200,
            "default": 50
          }
        }
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "../schemas/trip-record.json"
            }
          }
        }
      },
      "annotations": {
        "readOnlyHint": true,
        "openWorldHint": true
      },
      "x-openapi-operation": "listTripRecords",
      "x-agent-skill": "search-city-data-and-records"
    },
    {
