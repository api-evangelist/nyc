{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/nyc/main/nypd/schemas/shooting-incident.json",
  "title": "ShootingIncident",
  "description": "A shooting incident recorded by the NYPD (every incident in which a firearm was discharged with a victim struck). Canonical schema reconciling 'Shootings (2006-Present)' (5ucz-vwe8) and the 'ARCHIVED NYPD Shooting Incident Data (Historic)' (833y-fsy8, 26 columns). Keyed on INCIDENT_KEY. One incident may map to multiple victims.",
  "type": "object",
  "x-source": {
    "opendata_current": "https://data.cityofnewyork.us/d/5ucz-vwe8",
    "opendata_historic": "https://data.cityofnewyork.us/d/833y-fsy8"
  },
  "properties": {
    "incidentKey": { "type": "string", "description": "Randomly generated persistent incident identifier (INCIDENT_KEY); shared across all victims of one incident." },
    "occurredDate": { "type": ["string", "null"], "format": "date", "description": "Date of the shooting (OCCUR_DATE)." },
    "occurredTime": { "type": ["string", "null"], "description": "Time of the shooting (OCCUR_TIME)." },
    "borough": { "$ref": "_common.json#/$defs/Borough" },
    "precinct": { "type": ["integer", "null"], "description": "Precinct of occurrence (PRECINCT)." },
    "statisticalMurderFlag": { "type": ["boolean", "null"], "description": "Whether the shooting resulted in a victim's death, counted as a murder (STATISTICAL_MURDER_FLAG)." },
    "locationOfOccurrence": { "type": ["string", "null"], "description": "Inside/outside descriptor (LOC_OF_OCCUR_DESC)." },
    "locationClassification": { "type": ["string", "null"], "description": "Location classification (LOC_CLASSFCTN_DESC), e.g. 'STREET', 'DWELLING'." },
    "locationDescription": { "type": ["string", "null"], "description": "Specific premises description (LOCATION_DESC)." },
    "jurisdictionCode": { "type": ["integer", "null"], "description": "JURISDICTION_CODE (0=Patrol, 1=Transit, 2=Housing)." },
    "perpetrator": { "$ref": "_common.json#/$defs/Demographics" },
    "victim": { "$ref": "_common.json#/$defs/Demographics" },
    "location": { "$ref": "_common.json#/$defs/GeoLocation" },
    "coordinates": { "$ref": "_common.json#/$defs/Coordinates" }
  },
  "required": ["incidentKey"],
  "additionalProperties": false
}
