  "server": {
    "name": "io.nyc.cfb",
    "title": "NYC Campaign Finance Board (CFB)",
    "version": "0.1.0",
    "description": "Agent-native access to the New York City Campaign Finance Board \u2014 candidates for city office, campaign committees (filers), contributions (with intermediary/bundler detail), expenditures, public matching-funds payments, and disclosure statements from NYC Open Data and the Follow the Money database, plus the net-new ability to submit a disclosure statement (filing) that today lives only in the C-SMART application.",
    "instructions": "Use find_candidates / get_candidate to locate candidates for NYC office by election cycle, office, class, or borough and read their financial summaries. find_committees / get_committee cover authorized campaign committees (filers). find_contributions searches donations (including who bundled them as an intermediary); find_expenditures searches campaign spending by payee and purpose. find_public_funds_payments returns matching-funds payments under NYC's small-dollar program. find_disclosure_filings lists disclosure statements and their status (including late/missing). file_disclosure (net-new) submits a disclosure statement; it requires an authenticated filer and mutates state \u2014 confirm the filer, election cycle, statement number, and totals with the user before submitting, and set amendment=true with amendsFilingId to correct a prior statement."
  },
  "capabilities": {
    "tools": {
      "listChanged": false
    },
    "prompts": {
      "listChanged": false
    },
    "resources": {
      "listChanged": false,
      "subscribe": false
    }
  },
  "tools": [
    {
      "name": "find_candidates",
      "title": "Find Candidates",
      "description": "Search NYC candidates tracked by the CFB by election cycle, office, candidate class, incumbency, borough, and/or free text.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "electionCycle": {
            "type": "string"
          },
          "office": {
            "type": "string"
          },
          "class": {
            "type": "string"
          },
          "incumbent": {
            "type": "boolean"
          },
          "borough": {
            "type": "string",
            "enum": [
              "Manhattan",
              "Bronx",
              "Brooklyn",
              "Queens",
              "Staten Island"
            ]
          },
          "q": {
            "type": "string"
          },
          "page": {
            "type": "integer",
            "minimum": 1,
            "default": 1
          },
          "perPage": {
            "type": "integer",
            "minimum": 1,
            "maximum": 200,
            "default": 50
          }
        }
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "../schemas/candidate.json"
            }
          }
        }
      },
      "annotations": {
        "readOnlyHint": true,
        "openWorldHint": true
      },
      "x-openapi-operation": "listCandidates",
      "x-agent-skill": "search-city-data-and-records"
    },
    {
