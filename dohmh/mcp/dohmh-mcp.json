  "x-artifact": {
    "kind": "mcp-server-definition",
    "designFirst": true,
    "deployed": false,
    "note": "Design-first artifact only \u2014 describes the MCP tool surface, not a running server. Tool input/output schemas $ref the same object schemas as the OpenAPI; each tool maps to an OpenAPI operationId. Consolidates the read-heavy DOHMH Open Data (restaurant/rodent/childcare inspections, complaints) with the siloed transactional systems (ABC Eats, eVital/VitalChek, Accela) behind one agent contract; adds the net-new write workflow, ordering a vital record.",
    "openapi": "../openapi/dohmh.yaml",
    "schemas": "../schemas/"
  },
  "server": {
    "name": "io.nyc.dohmh",
    "title": "NYC Health (DOHMH)",
    "version": "0.1.0",
    "description": "Agent-native access to the NYC Department of Health and Mental Hygiene \u2014 restaurant grades & inspections, rodent inspections, childcare centers, clinics, and public-health complaints. Fronts NYC Open Data for the read-heavy records and the ABC Eats grade lookup; adds ordering and tracking of birth/death certificates (today locked in eVital/VitalChek).",
    "instructions": "Use find_food_establishments / get_food_establishment (and get_food_establishment_inspections) for restaurant grades and inspection history \u2014 the city's most-consumed dataset. find_inspections searches inspections across establishments. find_rodent_inspections answers 'are there rat signs at this address?'. find_childcare_centers covers permitted daycares and their violation rates. find_health_facilities locates DOHMH clinics by service and location. find_complaints surfaces indoor environmental complaints. order_vital_record (net-new) and track_vital_record_request require an authenticated user; order_vital_record mutates state and places a paid order \u2014 confirm all details with the user before submitting."
  },
