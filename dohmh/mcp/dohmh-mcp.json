    {
      "name": "find_food_establishments",
      "title": "Find Food Establishments",
      "description": "Search NYC restaurants / food establishments by borough, cuisine, current letter grade, ZIP, or free text.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "borough": {
            "type": "string",
            "enum": [
              "Manhattan",
              "Bronx",
              "Brooklyn",
              "Queens",
              "Staten Island"
            ]
          },
          "cuisine": {
            "type": "string"
          },
          "grade": {
            "type": "string",
            "enum": [
              "A",
              "B",
              "C",
              "Z",
              "N",
              "P",
              "G"
            ]
          },
          "zipCode": {
            "type": "string"
          },
          "q": {
            "type": "string"
          },
          "page": {
            "type": "integer",
            "minimum": 1,
            "default": 1
          },
          "perPage": {
            "type": "integer",
            "minimum": 1,
            "maximum": 200,
            "default": 50
          }
        }
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "../schemas/food-establishment.json"
            }
          }
        }
      },
      "annotations": {
        "readOnlyHint": true,
        "openWorldHint": true
