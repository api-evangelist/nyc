{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/nyc/main/dohmh/schemas/environmental-complaint.json",
  "title": "EnvironmentalComplaint",
  "description": "An indoor environmental / public-health complaint received by DOHMH (mold, indoor air quality, rodents/pests, lead, etc.), routed from 311. Canonical schema for the 'DOHMH Indoor Environmental Complaints' Open Data dataset (9jgj-bmct, 19 columns). Keyed on the complaint number.",
  "type": "object",
  "x-source": {
    "opendata": "https://data.cityofnewyork.us/d/9jgj-bmct",
    "intake": "https://portal.311.nyc.gov/"
  },
  "properties": {
    "complaintNumber": { "type": "string", "description": "Complaint number (Open Data 'complaint_number')." },
    "complaintType": { "type": ["string", "null"], "description": "311 complaint type (Open Data 'complaint_type_311')." },
    "descriptor": { "type": ["string", "null"], "description": "311 descriptor (Open Data 'descriptor_1_311')." },
    "status": { "type": ["string", "null"], "description": "Complaint status (Open Data 'complaint_status')." },
    "dateReceived": { "type": ["string", "null"], "format": "date", "description": "Date received (Open Data 'date_received')." },
    "address": { "$ref": "_common.json#/$defs/Address" },
    "geo": { "$ref": "_common.json#/$defs/GeoLocation" }
  },
  "required": ["complaintNumber"],
  "additionalProperties": false
}
