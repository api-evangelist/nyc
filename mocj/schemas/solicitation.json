{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/nyc/main/mocj/schemas/solicitation.json",
  "title": "Solicitation",
  "description": "A MOCJ procurement solicitation or notice — how the office contracts with the community-based organizations (grantees) that run its programs. Canonical schema reconciling the WordPress 'solicitation' (25) and 'notice' (26) custom post types under 'Contract with MOCJ'. There is no Open Data twin and no procurement API; today a would-be grantee reads these as web pages and responds via Vendor Enrollment / Contact Form 7 web forms.",
  "type": "object",
  "x-source": {
    "site": "https://criminaljustice.cityofnewyork.us/notices-solicitations/",
    "wp_rest_solicitation": "https://criminaljustice.cityofnewyork.us/wp-json/wp/v2/solicitation",
    "wp_rest_notice": "https://criminaljustice.cityofnewyork.us/wp-json/wp/v2/notice",
    "opendata": null,
    "opendata_gap": true
  },
  "properties": {
    "solicitationId": { "type": ["string", "integer", "null"], "description": "WordPress post ID." },
    "slug": { "type": ["string", "null"] },
    "title": { "type": "string", "description": "Solicitation / notice title." },
    "kind": { "type": ["string", "null"], "enum": ["Solicitation", "Notice", "RFP", "RFQ", "Concept Paper", null], "description": "Procurement instrument type." },
    "summary": { "type": ["string", "null"], "description": "Description / scope." },
    "url": { "type": ["string", "null"], "format": "uri", "description": "Canonical page." },
    "documentUrl": { "type": ["string", "null"], "format": "uri", "description": "Downloadable solicitation document, if any." },
    "status": { "type": ["string", "null"], "enum": ["Open", "Closed", "Awarded", "Cancelled", null], "description": "Solicitation status." },
    "issueArea": { "$ref": "_common.json#/$defs/IssueArea" },
    "postedDate": { "type": ["string", "null"], "format": "date" },
    "dueDate": { "type": ["string", "null"], "format": "date", "description": "Response deadline." }
  },
  "required": ["title"],
  "additionalProperties": false
}
