 "server": {
  "name": "io.nyc.hpd",
  "title": "NYC Housing (HPD)",
  "version": "0.1.0",
  "description": "Agent-native access to NYC Housing Preservation & Development — buildings, Housing Maintenance Code violations, complaints, owner registrations, housing litigation, and affordable-housing production. Exposes the private HPD Online backend and the 47 HPD Open Data datasets behind one owned surface; adds affordable-housing lottery applications and maintenance complaints as writes.",
  "instructions": "Use find_buildings / get_building to locate a property (by address, BBL, BIN, or Building ID), then get_building_violations and get_building_complaints for its conditions record. find_violations and find_complaints search citywide. find_registrations answers 'who owns / manages this building?'. find_litigation covers HPD housing-court cases and harassment findings. find_affordable_housing covers Housing New York production by building/project. file_complaint and apply_to_lottery (net-new) mutate state and carry PII — confirm every field with the user before submitting, and never invent applicant details.",
  "x-language": "ar"
 },
 "capabilities": {
  "tools": {
   "listChanged": false
  },
  "prompts": {
   "listChanged": false
  },
  "resources": {
   "listChanged": false,
   "subscribe": false
  }
 },
