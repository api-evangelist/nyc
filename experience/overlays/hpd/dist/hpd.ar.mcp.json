       "Bronx",
       "Brooklyn",
       "Queens",
       "Staten Island"
      ]
     },
     "bbl": {
      "type": "string"
     },
     "bin": {
      "type": "string"
     },
     "block": {
      "type": "string"
     },
     "lot": {
      "type": "string"
     },
     "councilDistrict": {
      "type": "integer",
      "minimum": 1,
      "maximum": 51
     },
     "q": {
      "type": "string"
     },
