{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/nyc/main/vote.nyc/schemas/election-result.json",
  "title": "ElectionResult",
  "description": "Results for a single contest. ASPIRATIONAL — the flagship gap. Today results exist ONLY as per-contest PDFs (a 'Recap' + an 'EDLevel' file) and in the separate legacy viewer enr.boenyc.gov (with ranked-choice rounds at /rcv/). This schema defines the machine-readable results shape — including RCV rounds — that has no equivalent today.",
  "type": "object",
  "x-source": {
    "website": "https://vote.nyc/page/election-results-summary",
    "legacy_viewer": "https://enr.boenyc.gov/",
    "opendata": null
  },
  "properties": {
    "contestId": { "type": "string", "description": "References contest.json." },
    "election": { "$ref": "_common.json#/$defs/ElectionReference" },
    "office": { "$ref": "_common.json#/$defs/OfficeDistrict" },
    "certified": { "type": ["boolean", "null"], "description": "Whether these are certified (final) results vs. unofficial." },
    "reportingLevel": { "type": "string", "enum": ["Contest", "ElectionDistrict"], "description": "Recap (contest total) vs EDLevel (per election district)." },
    "electionDistrict": { "type": ["string", "null"], "description": "For EDLevel results." },
    "totalBallots": { "type": ["integer", "null"] },
    "candidateResults": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "candidateId": { "type": ["string", "null"] },
          "name": { "type": "string" },
          "party": { "type": ["string", "null"] },
          "votes": { "type": "integer", "minimum": 0 },
          "percent": { "type": ["number", "null"] }
        },
        "required": ["name", "votes"],
        "additionalProperties": false
      }
    },
    "rankedChoiceRounds": {
      "type": ["array", "null"],
      "description": "For RCV contests — each elimination round (from enr.boenyc.gov/rcv/).",
      "items": {
        "type": "object",
        "properties": {
          "round": { "type": "integer", "minimum": 1 },
          "tallies": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "votes": { "type": "integer" },
                "eliminated": { "type": "boolean" }
              },
              "required": ["name", "votes"],
              "additionalProperties": false
            }
          }
        },
        "required": ["round", "tallies"],
        "additionalProperties": false
      }
    },
    "sourcePdf": { "type": ["string", "null"], "format": "uri", "description": "The originating result PDF, for provenance." }
  },
  "required": ["contestId", "election", "reportingLevel", "candidateResults"],
  "additionalProperties": false
}
