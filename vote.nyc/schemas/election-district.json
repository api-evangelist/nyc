{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/nyc/main/vote.nyc/schemas/election-district.json",
  "title": "ElectionDistrict",
  "description": "A NYC election district (ED) — the smallest election geography. Reconciles the DCP 'Election Districts' boundaries with BOENY 'Election District Poll Sites' (i3a3-qxkf).",
  "type": "object",
  "x-source": {
    "opendata": ["Election Districts (DCP)", "https://data.cityofnewyork.us/d/i3a3-qxkf"]
  },
  "properties": {
    "electionDistrict": { "type": "string", "description": "ED identifier (AD/ED, e.g. '65/001')." },
    "assemblyDistrict": { "type": ["integer", "null"], "description": "State Assembly district the ED sits in." },
    "borough": { "$ref": "_common.json#/$defs/Borough" },
    "pollSiteNumber": { "type": ["string", "null"], "description": "Assigned poll site (references poll-site.json)." },
    "geometryUrl": { "type": ["string", "null"], "format": "uri", "description": "DCP boundary (GeoJSON/shapefile)." }
  },
  "required": ["electionDistrict"],
  "additionalProperties": false
}
