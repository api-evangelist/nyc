  "server": {
    "name": "io.nyc.queensbp",
    "title": "Queens Borough President (QBP)",
    "version": "0.1.0",
    "description": "Agent-native access to the Office of the Queens Borough President \u2014 Queens' 14 community boards and their appointed members (from NYC Open Data), advisory land-use (ULURP) recommendations, discretionary funding awards, public events, and Newsroom press releases, plus the net-new ability to apply to serve on a community board, which today exists only as an HTML/PDF form.",
    "instructions": "Use find_community_boards / get_community_board to locate a board (district manager, chair, monthly meeting) and find_community_board_members / find_appointments for who serves on it (the two published Open Data datasets). find_land_use_recommendations covers the Borough President's advisory ULURP positions; find_discretionary_funding covers capital/expense awards to nonprofits, schools, and cultural groups; find_events and find_press_releases cover the Newsroom. apply_to_community_board (net-new) submits a community board application; it requires an authenticated resident and mutates state \u2014 confirm the applicant's district eligibility, board preference, and statement of interest before submitting. Note: most QBP data has no API today and the site's own WordPress REST API is enabled but empty; treat results as a proposed contract."
  },
  "capabilities": {
    "tools": {
      "listChanged": false
    }
  },
  "tools": [
