      "title": "Find Community Boards",
      "description": "List Queens' community boards with their district manager, chair, office, and monthly meeting.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "q": {
            "type": "string"
          },
          "page": {
            "type": "integer",
            "minimum": 1,
            "default": 1
          },
          "perPage": {
            "type": "integer",
            "minimum": 1,
            "maximum": 200,
            "default": 50
          }
        }
      },
      "outputSchema": {
        "type": "object",
        "properties": {
