{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/nyc/main/dob/schemas/job-filing.json",
  "title": "JobFiling",
  "description": "A DOB job application filing — an application to perform construction/alteration work on a building, tracked from pre-filing through approval. Reconciles the legacy 'DOB Job Application Filings' Open Data extract (ic3t-wcy2, 95 columns, 2.4M page views — the most-viewed DOB dataset) with the newer 'DOB NOW: Build – Job Application Filings' extract (w9ak-ipjd). The record of the filing lives in BIS (legacy jobs) or DOB NOW (a810-dobnow.nyc.gov); Open Data is a nightly batch dump (see DOBRunDate).",
  "type": "object",
  "x-source": {
    "opendata_bis": "https://data.cityofnewyork.us/d/ic3t-wcy2",
    "opendata_dobnow": "https://data.cityofnewyork.us/d/w9ak-ipjd",
    "app": "https://a810-dobnow.nyc.gov (DOB NOW: Build) / https://a810-bisweb.nyc.gov (BIS)",
    "note": "Filing systems are browser-only; the only machine-readable output is a nightly Socrata extract."
  },
  "properties": {
    "jobNumber": { "type": "string", "description": "Legacy BIS Job # (Open Data 'Job #') or DOB NOW Job Filing Number." },
    "docNumber": { "type": ["string", "null"], "description": "Document # within the job (Open Data 'Doc #')." },
    "jobType": { "type": ["string", "null"], "description": "e.g. A1 / A2 / A3 (alteration), NB (new building), DM (demolition) (Open Data 'Job Type')." },
    "jobStatus": { "type": ["string", "null"], "description": "Status code (Open Data 'Job Status')." },
    "jobStatusDescription": { "type": ["string", "null"], "description": "Open Data 'Job Status Descrp'." },
    "jobDescription": { "type": ["string", "null"], "description": "Free-text scope of work (Open Data 'Job Description')." },
    "bin": { "type": ["string", "null"], "description": "Open Data 'Bin #'." },
    "bbl": { "type": ["string", "null"] },
    "borough": { "$ref": "_common.json#/$defs/Borough" },
    "address": { "$ref": "_common.json#/$defs/Address" },
    "geography": { "$ref": "_common.json#/$defs/GeographySpine" },
    "coordinates": { "$ref": "_common.json#/$defs/Coordinates" },
    "buildingType": { "type": ["string", "null"] },
    "initialCost": { "type": ["string", "number", "null"], "description": "Estimated cost of work (Open Data 'Initial Cost')." },
    "proposedDwellingUnits": { "type": ["integer", "null"] },
    "proposedOccupancy": { "type": ["string", "null"] },
    "existingOccupancy": { "type": ["string", "null"] },
    "professionalCert": { "type": ["boolean", "null"], "description": "Professionally self-certified (Open Data 'Professional Cert')." },
    "applicant": { "$ref": "_common.json#/$defs/PartyReference" },
    "owner": { "$ref": "_common.json#/$defs/PartyReference" },
    "dates": {
      "type": "object",
      "properties": {
        "preFiling": { "type": ["string", "null"], "format": "date", "description": "Open Data 'Pre- Filing Date'." },
        "fullyPaid": { "type": ["string", "null"], "format": "date" },
        "approved": { "type": ["string", "null"], "format": "date", "description": "Open Data 'Approved'." },
        "fullyPermitted": { "type": ["string", "null"], "format": "date" },
        "latestAction": { "type": ["string", "null"], "format": "date", "description": "Open Data 'Latest Action Date'." },
        "signoff": { "type": ["string", "null"], "format": "date" }
      },
      "additionalProperties": false
    }
  },
  "required": ["jobNumber"],
  "additionalProperties": false
}
