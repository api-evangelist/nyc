{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/nyc/main/dcwp/schemas/business-license.json",
  "title": "BusinessLicense",
  "description": "A DCWP-issued business license (the Licensee record) — the core regulated unit of the Department of Consumer and Worker Protection. Canonical schema reconciling the 'Issued Licenses' dataset (w7w3-xahh, 31 columns) and 'Historical Licenses' (m4ph-grrm). Keyed on License Number + Business Unique ID.",
  "type": "object",
  "x-source": {
    "opendata_issued": "https://data.cityofnewyork.us/d/w7w3-xahh",
    "opendata_historical": "https://data.cityofnewyork.us/d/m4ph-grrm",
    "site": "https://www.nyc.gov/site/dca/businesses/licenses.page"
  },
  "properties": {
    "licenseNumber": { "type": "string", "description": "'License Number' — primary key of the issued license." },
    "licenseType": { "type": ["string", "null"], "description": "'License Type' (e.g. Home Improvement Contractor, Sidewalk Cafe, General Vendor, Tobacco Retail Dealer)." },
    "licenseStatus": { "type": ["string", "null"], "description": "'License Status' (e.g. Active, Inactive)." },
    "business": { "$ref": "_common.json#/$defs/BusinessReference" },
    "contactPhone": { "type": ["string", "null"], "description": "'Contact Phone'." },
    "initialIssuanceDate": { "type": ["string", "null"], "format": "date", "description": "'Initial Issuance Date'." },
    "expirationDate": { "type": ["string", "null"], "format": "date", "description": "'Expiration Date'." },
    "address": { "$ref": "_common.json#/$defs/Address" },
    "geography": { "$ref": "_common.json#/$defs/Geography" },
    "coordinates": { "$ref": "_common.json#/$defs/Coordinates" },
    "details": { "type": ["string", "null"], "description": "'Details' — free-text license detail/endorsement." }
  },
  "required": ["licenseNumber"],
  "additionalProperties": false
}
