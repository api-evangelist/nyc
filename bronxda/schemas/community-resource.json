{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/nyc/main/bronxda/schemas/community-resource.json",
  "title": "CommunityResource",
  "description": "A public-facing resource, service, or information item the Bronx DA offers the community — sealing old convictions (CPL 160.59), the BronxCAMS camera-sharing program, 'Your Day in Court', immigrant-affairs help, and important phone numbers. Reverse-engineered from /html/outreach/ and the homepage 'Important Numbers'. No API or Open Data today.",
  "type": "object",
  "x-source": {
    "outreach_sealing": "https://www.bronxda.nyc.gov/html/outreach/sealing-old-convictions.shtml",
    "outreach_bronxcams": "https://www.bronxda.nyc.gov/html/outreach/enroll-in-bronxcams.shtml",
    "outreach_immigrant": "https://www.bronxda.nyc.gov/html/outreach/immigrant-affairs-unit.shtml",
    "opendata": null,
    "opendata_gap": true
  },
  "properties": {
    "name": { "type": "string", "description": "Name of the resource or service." },
    "category": {
      "type": ["string", "null"],
      "description": "Type of community resource.",
      "enum": ["Record Sealing", "Public Safety", "Immigrant Services", "Court Navigation", "Reentry", "Youth", "Hotline / Important Number", "Other", null]
    },
    "description": { "type": ["string", "null"], "description": "What the resource provides." },
    "eligibility": { "type": ["string", "null"], "description": "Who qualifies / how to qualify." },
    "howToAccess": { "type": ["string", "null"], "description": "Steps to use the resource (apply, call, enroll, walk in)." },
    "office": { "$ref": "_common.json#/$defs/OfficeReference" },
    "bureau": { "$ref": "_common.json#/$defs/Bureau" },
    "contact": { "$ref": "_common.json#/$defs/ContactInfo" },
    "geography": { "$ref": "_common.json#/$defs/Geography" },
    "coordinates": { "$ref": "_common.json#/$defs/Coordinates" },
    "url": { "type": ["string", "null"], "format": "uri" }
  },
  "required": ["name"],
  "additionalProperties": false
}
