      "title": "Find Reservoir Levels",
      "description": "List reservoir-level observations across the NYC water-supply system by reservoir, system (Catskill/Delaware/Croton), or time window.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "reservoir": {
            "type": "string"
          },
          "system": {
            "type": "string",
            "enum": [
              "Catskill",
              "Delaware",
              "Croton"
            ]
          },
          "from": {
            "type": "string",
            "format": "date-time"
          },
          "to": {
            "type": "string",
            "format": "date-time"
          },
          "page": {
            "type": "integer",
            "minimum": 1,
            "default": 1
          },
          "perPage": {
            "type": "integer",
            "minimum": 1,
            "maximum": 200,
            "default": 50
          }
        }
