  "x-artifact": {
    "kind": "mcp-server-definition",
    "designFirst": true,
    "deployed": false,
    "note": "Design-first artifact only \u2014 describes the MCP tool surface, not a running server. Tool input/output schemas $ref the same object schemas as the OpenAPI; each tool maps to an OpenAPI operationId. Surfaces DEP's open environmental reference data (reservoir levels, water consumption, water quality, green infrastructure, hydrants, permits) and adds report_water_problem \u2014 the net-new write workflow today split between NYC311 and the login-walled uMAX My DEP Account portal.",
    "openapi": "../openapi/dep.yaml",
    "schemas": "../schemas/"
  },
  "server": {
    "name": "io.nyc.dep",
    "title": "NYC Environmental Protection (DEP)",
    "version": "0.1.0",
    "description": "Agent-native access to the New York City Department of Environmental Protection \u2014 reservoir levels and citywide water consumption, harbor/drinking-water/watershed/lead-copper water quality, green-infrastructure assets, hydrants, and water/air/asbestos permits from NYC Open Data, plus the net-new ability to report and track a water or sewer problem (water service request) that today is split between NYC311 and the uMAX billing portal.",
    "instructions": "Use find_reservoir_levels for water-supply state and find_water_consumption for citywide usage. find_water_quality searches samples across DEP's programs (Harbor, Drinking Water Distribution, Watershed, Lead and Copper) \u2014 analyte values live in the sample's 'measurements' map and may be comparator strings like '<1' because DEP publishes many analytes as free text. find_green_infrastructure / get_green_infrastructure cover stormwater assets; find_hydrants / get_hydrant cover distribution assets; find_permits covers water/sewer, clean-air (CATS), and asbestos permits. report_water_problem (net-new) creates a water/sewer service request; it mutates state \u2014 confirm the location, category, and description with the user before submitting, and set emergency=true for water-main breaks, sewer backups into a home, flooding, or no water so it routes to DEP's 24-hour customer service. list_my_service_requests and get_service_request read a customer's own tickets."
  },
  "capabilities": {
    "tools": {
      "listChanged": false
    }
  },
  "tools": [
