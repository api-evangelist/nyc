{
  "x-artifact": {
    "kind": "mcp-server-definition",
    "designFirst": true,
    "deployed": false,
    "note": "Design-first artifact only \u2014 describes the MCP tool surface, not a running server. Tool input/output schemas $ref the same object schemas as the OpenAPI; each tool maps to an OpenAPI operationId. NYPL is the counter-example: it already operates real public APIs (Digital Collections, Locations, Research Catalog). This artifact unifies them into one agent-native contract and adds place_hold \u2014 the net-new write workflow that today has no clean, documented public API.",
    "openapi": "../openapi/nypl.yaml",
    "schemas": "../schemas/"
  },
  "server": {
    "name": "io.nyc.nypl",
    "title": "New York Public Library (NYPL)",
    "version": "0.1.0",
    "description": "Agent-native access to the New York Public Library \u2014 search Digital Collections, find branches and their hours/amenities/events, and search the Research Catalog, all over NYPL's already-real public APIs unified into one contract, plus the net-new ability to place and track a hold (reservation) on a catalog item.",
    "instructions": "Use search_digital_collections / get_digital_item to explore digitized items (set publicDomainOnly for reusable images); list_collections for curated groupings. find_branches / get_branch return NYPL locations with hours, amenities, and accessibility (NYPL serves Manhattan, the Bronx, and Staten Island; Brooklyn and Queens have separate systems). find_events and get_branch_events cover public programs and exhibitions. search_catalog / get_catalog_item query the Research and circulating catalog; only circulating, holdable copies can be reserved. list_my_holds and place_hold require an authenticated patron and never expose other patrons' data \u2014 place_hold mutates state and needs patron eligibility, so confirm the exact item (bibId) and pickup branch with the user before submitting."
  },
